---
import { apps } from "../data/apps.ts";

const bzzt = apps.find((a) => a.id === "bzzt")!;
const cmok = apps.find((a) => a.id === "cmok")!;
const nwd  = apps.find((a) => a.id === "nwd")!;

// strip the "Dating: " / "Safety: " / "Racing: " prefix and the trailing period
const cleanPatch = (s: string) =>
  s.replace(/^.*?:\s*/, "").replace(/\.$/, "");

const modes = [
  {
    id: "dating",
    n: "01",
    label: "Dating",
    accent: "bzzt",
    broken: bzzt.categoryDefault,
    patch: cleanPatch(bzzt.categoryPatch[0]),
    newSteps: bzzt.loopSteps,
    brand: "BZZT",
    brandClass: "font-mono font-bold uppercase tracking-[-0.02em]",
    appMeta: "live signal · 30-min window",
    appCta: "Open in App Store",
    href: bzzt.href!,
  },
  {
    id: "safety",
    n: "02",
    label: "Safety",
    accent: "cmok",
    broken: cmok.categoryDefault,
    patch: cleanPatch(cmok.categoryPatch[0]),
    newSteps: cmok.loopSteps,
    brand: "cmok",
    brandClass: "font-display italic lowercase tracking-[-0.02em]",
    appMeta: "daily sign · close circle",
    appCta: "Open in App Store",
    href: cmok.href!,
  },
  {
    id: "racing",
    n: "03",
    label: "Racing",
    accent: "nwd",
    broken: nwd.categoryDefault,
    patch: cleanPatch(nwd.categoryPatch[0]),
    newSteps: nwd.loopSteps,
    brand: "NWD",
    brandClass: "font-display tracking-[-0.04em]",
    appMeta: "verified gravity league · seasonal podiums",
    appCta: "Open NWD",
    href: nwd.href!,
  },
];
---

<section class="engine relative min-h-[100svh] flex flex-col border-b border-line overflow-hidden" aria-label="Strange Loop Engine">

  <!-- ─── radio inputs (CSS-only state) ─── -->
  <input type="radio" name="mode" id="mode-dating" class="console-state" checked aria-label="Dating mode" />
  <input type="radio" name="mode" id="mode-safety" class="console-state" aria-label="Safety mode" />
  <input type="radio" name="mode" id="mode-racing" class="console-state" aria-label="Racing mode" />

  <!-- ─── top status ─── -->
  <header class="relative border-b border-line">
    <span class="absolute top-3 left-3 reg-cross" aria-hidden="true"></span>
    <span class="absolute top-3 right-3 reg-cross" aria-hidden="true"></span>

    <div class="px-5 sm:px-8 py-3 flex items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2 shrink-0">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]" style="animation: blink-soft 2s infinite;"></span>
        <span class="text-ink">Strange loop engine</span>
      </span>
      <span class="hidden md:inline">SWA.OS · 3 patches available</span>
      <span class="text-right shrink-0">Warsaw · 2026</span>
    </div>
  </header>

  <!-- ─── HERO COPY ─── -->
  <div class="relative px-5 sm:px-12 lg:px-16 pt-10 sm:pt-14 pb-8">
    <h1 class="font-display tracking-[-0.04em] leading-[0.86] select-none">
      <span class="block text-[clamp(3.5rem,11vw,9.5rem)] text-ink">Small</span>
      <span class="block text-[clamp(3.5rem,11vw,9.5rem)] italic text-bzzt -mt-[1vw] pl-[4vw] sm:pl-[8vw]">weird</span>
      <span class="block text-[clamp(3.5rem,11vw,9.5rem)] text-ink -mt-[1vw]">Apps<span class="text-bzzt">.</span></span>
    </h1>

    <div class="mt-8 sm:mt-12 grid grid-cols-12 gap-4 sm:gap-8 items-end">
      <p class="col-span-12 md:col-span-7 font-display text-[clamp(1.6rem,3.2vw,2.6rem)] leading-[1.05] text-ink">
        Real problems.
        <span class="block italic text-ink-dim">Strange little loops.</span>
      </p>
      <p class="col-span-12 md:col-span-5 text-base sm:text-lg leading-relaxed text-ink-dim md:pl-6 md:border-l border-line">
        Tiny mobile apps that patch familiar categories
        by changing the loop.
      </p>
    </div>
  </div>

  <!-- ─── MODE TABS ─── -->
  <nav aria-label="Select category" class="border-y border-line bg-bg-soft/30">
    <ul class="grid grid-cols-3">
      {modes.map((m) => (
        <li>
          <label
            for={`mode-${m.id}`}
            data-mode-btn={m.id}
            class="mode-btn block px-4 sm:px-8 py-5 sm:py-7 cursor-pointer text-left border-r border-line last:border-r-0"
          >
            <span class="flex items-baseline justify-between gap-2 mb-2">
              <span class={`font-mono text-[10px] tracking-[0.28em] uppercase text-${m.accent}`}>[{m.n}]</span>
              <span class="active-marker hidden items-center gap-1.5 font-mono text-[9px] tracking-[0.22em] uppercase">
                <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent} shadow-[0_0_8px_currentColor] text-${m.accent}`} style="animation: blink-soft 1.4s infinite;"></span>
                <span class={`text-${m.accent}`}>active</span>
              </span>
            </span>
            <span class="block font-display tracking-[-0.02em] text-[clamp(1.6rem,3.4vw,2.6rem)] leading-[0.95] text-ink">{m.label}</span>
          </label>
        </li>
      ))}
    </ul>
  </nav>

  <!-- ─── ENGINE STAGE ─── -->
  <div class="engine-stage relative flex-1 flex flex-col justify-center px-5 sm:px-12 lg:px-16 py-10 sm:py-14">

    <!-- patch banner (animated, single instance per mode, fades on switch) -->
    <div class="absolute top-3 sm:top-6 left-1/2 -translate-x-1/2 z-10 pointer-events-none">
      {modes.map((m) => (
        <div data-mode={m.id} style="--slot-d: block">
          <div class={`engine-patch inline-flex items-center gap-3 px-4 py-2 border bg-bg-soft/95 border-${m.accent} text-${m.accent} shadow-[0_0_24px_currentColor]`}>
            <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent}`}></span>
            <span class="font-mono font-bold text-[11px] tracking-[0.32em] uppercase">patch {m.n} installed</span>
            <span aria-hidden="true" class="text-ink-faint">·</span>
            <span class="font-mono text-[11px] tracking-[0.22em] uppercase text-ink-dim">{m.patch}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- two loops side by side -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 sm:gap-8 items-start">

      <!-- BROKEN -->
      <div class="md:col-span-5">
        <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-flag mb-4 flex items-center justify-between">
          <span>▍ Broken category loop</span>
          <span class="text-flag/80">× failed</span>
        </p>
        {modes.map((m) => (
          <div data-mode={m.id} class="relative">
            <!-- fault diagonals across the broken column -->
            <span aria-hidden="true" class="broken-fault"></span>

            <ol class="broken-loop relative space-y-2.5">
              {m.broken.map((step) => (
                <li class="broken-step flex items-baseline gap-3 font-display text-[clamp(1.5rem,2.8vw,2.2rem)] leading-[1]">
                  <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-5">×</span>
                  <span class="line-through decoration-flag/70 decoration-2 text-ink-dim">{step}</span>
                  <span aria-hidden="true" class="font-mono text-[9px] tracking-[0.28em] uppercase text-flag/55 ml-auto">null</span>
                </li>
              ))}
              <li aria-hidden="true" class="font-mono text-[10px] tracking-[0.28em] uppercase text-flag/70 pl-8 pt-3 flex items-center gap-1.5">
                <span class="text-base">↺</span>
                <span>repeats · no exit</span>
              </li>
            </ol>
          </div>
        ))}
      </div>

      <!-- transformation gap -->
      <div class="md:col-span-2 flex md:flex-col items-center justify-center gap-2 md:py-8">
        <span aria-hidden="true" class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink-faint">patched</span>
        <span aria-hidden="true" class="text-ink-faint text-2xl md:text-3xl">
          <span class="md:hidden">↓</span>
          <span class="hidden md:inline">→</span>
        </span>
      </div>

      <!-- NEW -->
      <div class="md:col-span-5">
        {modes.map((m) => (
          <div data-mode={m.id}>
            <div class={`relative bg-${m.accent}/[0.06] border border-${m.accent}/35 p-5 sm:p-6 text-${m.accent}`}>
              <!-- pulse line traveling down the left edge -->
              <span aria-hidden="true" class="swa-trace"></span>

              <!-- corner pulse -->
              <span aria-hidden="true" class={`absolute top-3 right-3 block w-2 h-2 rounded-full bg-${m.accent} shadow-[0_0_10px_currentColor]`} style="animation: blink-soft 1.6s infinite;"></span>

              <p class="font-mono text-[10px] tracking-[0.32em] uppercase mb-4 flex items-center justify-between">
                <span>▍ SWA loop</span>
                <span>✓ installed · running</span>
              </p>

              <ol class="space-y-2.5">
                {m.newSteps.map((step, i) => (
                  <li class="new-loop-step flex items-baseline gap-3 font-display text-[clamp(1.5rem,2.8vw,2.2rem)] leading-[1] text-ink" style={`animation-delay: ${0.45 + i * 0.13}s;`}>
                    <span aria-hidden="true" class={`swa-dot block w-2 h-2 rounded-full bg-${m.accent} text-${m.accent} shrink-0 mt-[0.4em]`}></span>
                    <span>{step}</span>
                  </li>
                ))}
                <li aria-hidden="true" class="font-mono text-[10px] tracking-[0.28em] uppercase opacity-70 pl-7 pt-2 flex items-center gap-1.5">
                  <span class="text-base">↺</span>
                  <span>repeats · live</span>
                </li>
              </ol>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- APP REVEAL + CTA — title-card moment -->
    <div class="mt-10 sm:mt-16 grid grid-cols-1 md:grid-cols-12 items-stretch gap-6 sm:gap-10">

      <div class="md:col-span-8">
        {modes.map((m) => (
          <div data-mode={m.id} class="app-reveal">
            <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink-faint mb-3">▍ Patched into</p>

            <div class={`app-card relative px-5 sm:px-7 py-5 sm:py-7 text-${m.accent}`}>
              <span class={`absolute top-3 left-3 block w-2 h-2 rounded-full bg-${m.accent} shadow-[0_0_10px_currentColor]`} aria-hidden="true" style="animation: blink-soft 1.6s infinite;"></span>

              <span class={`block ${m.brandClass} text-[clamp(3.5rem,9vw,7rem)] leading-[0.82]`}>
                {m.brand}<span class="text-ink">.</span>
              </span>

              <span class="block mt-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-dim">
                {m.appMeta}
              </span>

              <a
                href={m.href}
                target="_blank"
                rel="noopener"
                class={`mt-5 group inline-flex items-center gap-3 px-4 py-3 border border-${m.accent}/50 hover:bg-${m.accent}/15 hover:border-${m.accent} transition-colors font-mono text-[11px] tracking-[0.22em] uppercase`}
              >
                <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent} shadow-[0_0_6px_currentColor]`}></span>
                <span class="text-ink">{m.appCta}</span>
                <span aria-hidden="true" class="transition-transform group-hover:translate-x-1 text-ink">↗</span>
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="md:col-span-4 flex md:items-end md:justify-end">
        <a
          href="#console"
          class="group inline-flex items-center gap-3 px-5 py-4 border border-line text-ink hover:border-bzzt hover:text-bzzt transition-colors font-mono text-[11px] tracking-[0.22em] uppercase w-full md:w-auto justify-between"
        >
          <span class="flex items-center gap-3">
            <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]" style="animation: blink-soft 2s infinite;"></span>
            <span>Open the loop console</span>
          </span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-y-0.5">↓</span>
        </a>
      </div>
    </div>
  </div>
</section>
