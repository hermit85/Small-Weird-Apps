---
---

<section class="relative py-24 sm:py-36 border-t border-line overflow-hidden">

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8">

    <!-- header -->
    <div class="flex items-baseline justify-between gap-4 mb-12 sm:mb-16">
      <p class="font-mono text-[11px] tracking-[0.32em] uppercase text-ink">▍ Loop 04 · unassigned</p>
      <span aria-hidden="true" class="flex-1 h-px bg-line"></span>
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">in workshop</p>
    </div>

    <div class="grid grid-cols-12 gap-4 sm:gap-8">

      <!-- left: status report — like a system message for the next slot -->
      <dl class="col-span-12 md:col-span-7 space-y-3">
        <div class="grid grid-cols-12 gap-4 items-baseline border-b border-line pb-3">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Problem</dt>
          <dd class="col-span-8 md:col-span-9 font-display italic text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1.1] text-ink">
            not selected yet.
          </dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline border-b border-line pb-3">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Category</dt>
          <dd class="col-span-8 md:col-span-9 font-display italic text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1.1] text-ink">
            not safe.
          </dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline border-b border-line pb-3">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Interface</dt>
          <dd class="col-span-8 md:col-span-9 font-display italic text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1.1] text-ink">
            pending.
          </dd>
        </div>
      </dl>

      <!-- right: announcement -->
      <aside class="col-span-12 md:col-span-5 md:pl-8 md:border-l border-line flex flex-col justify-between gap-8">
        <div>
          <div class="flex items-center gap-3 mb-5">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full rounded-full bg-bzzt opacity-60" style="animation: blink-soft 2.4s ease-in-out infinite;"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-bzzt"></span>
            </span>
            <span class="font-mono text-[11px] tracking-[0.28em] uppercase text-bzzt">drafting</span>
          </div>
          <p class="font-display text-[clamp(1.4rem,2.8vw,2rem)] leading-[1.2] text-ink">
            The next app starts when a normal problem
            <span class="italic text-ink-dim">gets annoying enough.</span>
          </p>
        </div>

        <div class="border-t border-dashed border-line pt-5">
          <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">
            machine 04 / no slug yet
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>
