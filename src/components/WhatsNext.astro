<section class="relative py-24 sm:py-32 border-t border-line-soft">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint mb-12 sm:mb-16">
      ▍ What's next
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
      <div class="lg:col-span-8">
        <p class="font-display text-[clamp(2rem,5vw,3.5rem)] leading-[1.05] text-ink">
          More small weird apps.
        </p>
        <p class="mt-2 font-display italic text-[clamp(1.4rem,3.2vw,2.2rem)] leading-snug text-ink-dim">
          When the right problem shows up.
        </p>
      </div>

      <aside class="lg:col-span-4 lg:pl-8 lg:border-l border-line-soft">
        <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint mb-3">
          ▍ Workshop · in progress
        </p>
        <p class="text-base sm:text-lg leading-relaxed text-ink-dim">
          Currently in the workshop:
          <span class="text-ink">something quiet, useful and probably overthought.</span>
        </p>

        <div class="mt-6 flex items-center gap-3">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-bzzt opacity-60" style="animation: blink-soft 2.4s ease-in-out infinite;"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-bzzt"></span>
          </span>
          <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">
            Loop 04 · drafting
          </span>
        </div>
      </aside>
    </div>
  </div>
</section>
