---
const steps = [
  { label: "Real problem",     accent: "text-ink",     sub: "broken category"  },
  { label: "Loop mutation",    accent: "text-flag",    sub: "rewire the loop"  },
  { label: "Small weird app",  accent: "text-bzzt",    sub: "ship the machine" },
  { label: "Real moment",      accent: "text-nwd",     sub: "land in life"     },
];
---

<section class="relative border-t border-line overflow-hidden">
  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-28">

    <div class="flex items-baseline justify-between gap-4 mb-10">
      <p class="font-mono text-[11px] tracking-[0.32em] uppercase text-ink">▍ The loop</p>
      <span aria-hidden="true" class="flex-1 h-px bg-line"></span>
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">how each machine works</p>
    </div>

    <!-- horizontal on desktop, vertical on mobile -->
    <ol class="grid grid-cols-1 md:grid-cols-9 gap-y-6 md:gap-y-0 md:gap-x-2 items-center">
      {steps.map((s, i) => (
        <Fragment>
          <li class="md:col-span-2 flex flex-col gap-2 items-start md:items-center text-left md:text-center">
            <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">step {String(i + 1).padStart(2, "0")}</span>
            <span class={`font-display text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1] ${s.accent}`}>
              {s.label}
            </span>
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint italic">{s.sub}</span>
          </li>
          {i < steps.length - 1 && (
            <li aria-hidden="true" class="md:col-span-[0.33] md:flex hidden items-center justify-center text-ink-faint text-xl">
              →
            </li>
          )}
          {i < steps.length - 1 && (
            <li aria-hidden="true" class="md:hidden flex items-center justify-start text-ink-faint text-xl pl-2">
              ↓
            </li>
          )}
        </Fragment>
      ))}
      <!-- final repeat ↺ -->
      <li aria-hidden="true" class="md:col-span-1 flex items-center justify-start md:justify-center mt-4 md:mt-0">
        <span class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink flex items-center gap-2">
          <span class="text-2xl">↺</span>
          <span>repeat</span>
        </span>
      </li>
    </ol>

    <p class="mt-12 sm:mt-14 font-display italic text-[clamp(1.2rem,2.4vw,1.6rem)] leading-snug text-ink-dim max-w-3xl">
      Three machines run this loop in three different broken categories.
      <span class="block text-ink-faint not-italic font-mono text-[11px] tracking-[0.22em] uppercase mt-3">↓ machines below</span>
    </p>
  </div>
</section>
