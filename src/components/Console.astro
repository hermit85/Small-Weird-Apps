---
import { apps } from "../data/apps.ts";
import RadarArtifact from "./artifacts/RadarArtifact.astro";
import CircleArtifact from "./artifacts/CircleArtifact.astro";
import RaceArtifact from "./artifacts/RaceArtifact.astro";

const bzzt = apps.find((a) => a.id === "bzzt")!;
const cmok = apps.find((a) => a.id === "cmok")!;
const nwd  = apps.find((a) => a.id === "nwd")!;

const meta = [
  { id: "bzzt", n: "01", cat: "Proximity",   short: "dating without endless swiping",       brand: "BZZT", brandClass: "font-mono font-bold uppercase tracking-tight",     accent: "bzzt", data: bzzt, status: "scanning" },
  { id: "cmok", n: "02", cat: "Reassurance", short: "care without panic theatre",            brand: "cmok", brandClass: "font-display italic lowercase",                     accent: "cmok", data: cmok, status: "ok sent" },
  { id: "nwd",  n: "03", cat: "Gravity",     short: "racing without waiting for an event",   brand: "NWD",  brandClass: "font-display tracking-[-0.02em]",                  accent: "nwd",  data: nwd,  status: "gate armed" },
];
---

<form class="console" aria-label="SWA loop console">

  <!-- ─── radio inputs ─── -->
  <input type="radio" name="loop" id="loop-bzzt" class="console-state" checked aria-label="Loop 01 — BZZT, proximity" />
  <input type="radio" name="loop" id="loop-cmok" class="console-state" aria-label="Loop 02 — cmok, reassurance" />
  <input type="radio" name="loop" id="loop-nwd"  class="console-state" aria-label="Loop 03 — NWD, gravity" />

  <!-- ─── TOP STRIP (trimmed) ─── -->
  <header class="console-top relative border-b border-line">
    <span class="absolute top-3 left-3 reg-cross" aria-hidden="true"></span>
    <span class="absolute top-3 right-3 reg-cross" aria-hidden="true"></span>

    <div class="px-5 sm:px-8 py-3 flex items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2 shrink-0">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]" style="animation: blink-soft 2s infinite;"></span>
        <span class="text-ink">SWA.OS</span>
        <span aria-hidden="true">·</span>
        <span>3 loops</span>
        <span aria-hidden="true" class="hidden sm:flex items-center gap-1 ml-1">
          <span class="block w-1 h-1 rounded-full bg-bzzt" style="animation: blink-soft 2.2s infinite;"></span>
          <span class="block w-1 h-1 rounded-full bg-cmok" style="animation: blink-soft 2.2s 0.7s infinite;"></span>
          <span class="block w-1 h-1 rounded-full bg-nwd"  style="animation: blink-soft 2.2s 1.4s infinite;"></span>
        </span>
      </span>
      <span class="text-right shrink-0">Warsaw · 2026</span>
    </div>
  </header>

  <!-- ─── LEFT: SELECTOR ─── -->
  <aside class="console-select border-r border-line flex flex-col">

    <!-- brand (desktop only) -->
    <div class="brand-block px-4 sm:px-5 py-6 border-b border-line">
      <p class="font-display tracking-[-0.04em] leading-[0.9]">
        <span class="block text-[clamp(1.6rem,2.4vw,2.4rem)] text-ink">Small</span>
        <span class="block text-[clamp(1.6rem,2.4vw,2.4rem)] italic text-bzzt">weird</span>
        <span class="block text-[clamp(1.6rem,2.4vw,2.4rem)] text-ink">Apps<span class="text-bzzt">.</span></span>
      </p>
    </div>

    <!-- selector -->
    <nav aria-label="Select loop" class="loops flex-1">
      <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink-faint px-4 sm:px-5 py-4 border-b border-line">
        ▍ Select loop
      </p>

      <ul class="px-4 sm:px-5 py-5 space-y-2.5">
        {meta.map((m) => (
          <li>
            <label
              for={`loop-${m.id}`}
              data-loop-btn={m.id}
              class="loop-btn group relative p-3 sm:p-3.5"
            >
              <!-- top row: number + active dot -->
              <div class="flex items-center justify-between mb-1.5">
                <span class={`font-mono font-bold text-[clamp(1.1rem,1.6vw,1.4rem)] tracking-[-0.02em] text-${m.accent}`}>{m.n}</span>
                <span class="active-marker items-center gap-1.5">
                  <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent} shadow-[0_0_6px_currentColor] text-${m.accent}`} style="animation: blink-soft 1.4s infinite;"></span>
                </span>
              </div>

              <!-- category -->
              <div class="font-mono font-bold tracking-[0.18em] uppercase text-[11px] text-ink mb-1">
                {m.cat}
              </div>

              <!-- brand · short -->
              <div class="text-[12px] leading-tight text-ink-dim">
                <span class={`${m.brandClass} text-ink`}>{m.brand}</span>
                <span class="opacity-60"> · </span>
                <span>{m.short}</span>
              </div>
            </label>
          </li>
        ))}
      </ul>

      <!-- 4th slot — unassigned (desktop) -->
      <div class="slot-04 mx-4 sm:mx-5 mb-5 px-3 sm:px-3.5 py-2.5 border border-dashed border-line opacity-50">
        <div class="flex items-center justify-between mb-1">
          <span class="font-mono font-bold text-[clamp(1.1rem,1.6vw,1.4rem)] tracking-[-0.02em] text-ink-faint">04</span>
          <span class="font-mono text-[9px] tracking-[0.22em] uppercase text-ink-faint">drafting</span>
        </div>
        <div class="font-mono font-bold tracking-[0.18em] uppercase text-[11px] text-ink-faint">unassigned</div>
      </div>
    </nav>

    <!-- bottom: manifesto (desktop) -->
    <div class="manifesto-block px-4 sm:px-5 py-5 border-t border-line">
      <p class="font-display text-[clamp(1rem,1.4vw,1.2rem)] leading-[1.15] text-ink">
        Real problems.
        <span class="block italic text-ink-dim">Strange little loops.</span>
      </p>
    </div>
  </aside>

  <!-- ─── CENTER: ACTIVE ARTIFACT ─── -->
  <section class="console-artifact relative border-r border-line min-h-[60svh] lg:min-h-0 flex flex-col">

    <!-- compact artifact bar -->
    <div class="border-b border-line px-5 sm:px-8 py-3 font-mono text-[10px] tracking-[0.28em] uppercase">
      {meta.map((m) => (
        <span data-loop={m.id} style="--slot-d: flex" class={`items-center justify-between w-full text-${m.accent}/85`}>
          <span>Active machine · {m.n} / {m.cat}</span>
          <span class="hidden sm:inline-flex items-center gap-2">
            <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent}`} style="animation: blink-soft 1.6s infinite;"></span>
            {m.status}
          </span>
        </span>
      ))}
    </div>

    <!-- PATCH INSTALLED micro-event (overlay banner that flashes on loop change) -->
    <div class="absolute top-12 sm:top-14 left-1/2 -translate-x-1/2 z-10 pointer-events-none">
      {meta.map((m) => (
        <div data-loop={m.id} style="--slot-d: block">
          <div class={`patch-flash inline-flex items-center gap-3 px-4 py-2 border border-${m.accent} bg-bg-soft/95 shadow-[0_0_24px_currentColor] text-${m.accent}`}>
            <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${m.accent}`}></span>
            <span class="font-mono font-bold text-[10px] tracking-[0.32em] uppercase">patch {m.n} installed</span>
            <span aria-hidden="true" class="text-ink-faint">·</span>
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-dim normal-case">
              {m.data.categoryPatch[1].toLowerCase().replace(/\.$/, "")}
            </span>
          </div>
        </div>
      ))}
    </div>

    <!-- machine wordmark + tagline -->
    <div class="flex-1 px-5 sm:px-12 py-8 sm:py-10 flex flex-col gap-6 sm:gap-8 justify-between">

      <div>
        {meta.map((m) => (
          <span data-loop={m.id}>
            <span class={`block ${m.brandClass} text-[clamp(4rem,12vw,12rem)] leading-[0.85] text-${m.accent}`}>
              {m.brand}<span class="text-ink">.</span>
            </span>
            <p class="mt-3 font-display italic text-[clamp(1.4rem,2.4vw,2rem)] leading-[1.1] text-ink">
              {m.data.taglinePl}
              <span class="block mt-1 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint not-italic">
                en · {m.data.tagline}
              </span>
            </p>
          </span>
        ))}
      </div>

      <!-- the artifact itself — large, dominant -->
      <div class="relative flex-1 flex items-center justify-center min-h-[42svh] py-2">
        <div data-loop="bzzt" class="w-full max-w-[680px]"><RadarArtifact /></div>
        <div data-loop="cmok" class="w-full max-w-[680px]"><CircleArtifact /></div>
        <div data-loop="nwd"  class="w-full max-w-[720px]"><RaceArtifact  /></div>
      </div>
    </div>
  </section>

  <!-- ─── RIGHT: INSPECTOR ─── -->
  <aside class="console-details flex flex-col">

    {meta.map((m) => (
      <div data-loop={m.id} style="--slot-d: flex" class="flex-1 flex-col">

        <!-- INPUT -->
        <section class="border-b border-line px-5 py-5">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-flag mb-2">▍ Input</p>
          <p class="font-display text-[clamp(1.4rem,2vw,1.7rem)] leading-[1.1] text-ink">
            <span class="text-flag mr-2 align-middle">×</span>
            <span class="line-through decoration-flag/80 decoration-2 italic text-ink-dim">{m.data.input[0]}</span>
          </p>
        </section>

        <!-- CATEGORY DEFAULT — failed -->
        <section class="border-b border-line px-5 py-5">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint mb-2 flex items-center justify-between">
            <span>▍ Category default</span>
            <span class="text-flag">× failed</span>
          </p>
          <p class="font-display text-[clamp(1.1rem,1.6vw,1.35rem)] leading-[1.2] text-ink-dim line-through decoration-flag/55 decoration-1">
            {m.data.categoryDefault.join(" → ")}
          </p>
        </section>

        <!-- ↓ patched connector -->
        <div class="px-5 py-3 border-b border-line flex items-center gap-3 font-mono text-[10px] tracking-[0.32em] uppercase text-ink-faint">
          <span aria-hidden="true" class={`block w-3 h-3 border-l border-b border-${m.accent}/60 -rotate-45 -mt-2 -ml-1`}></span>
          <span class={`text-${m.accent}/80`}>patched</span>
          <span aria-hidden="true" class={`flex-1 h-px bg-${m.accent}/30`}></span>
        </div>

        <!-- SWA MUTATION — installed -->
        <section class={`border-b border-line px-5 py-5 bg-${m.accent}/[0.06]`}>
          <p class={`font-mono text-[10px] tracking-[0.28em] uppercase text-${m.accent} mb-2 flex items-center justify-between`}>
            <span>▍ SWA mutation</span>
            <span class={`text-${m.accent}`}>✓ installed</span>
          </p>
          <p class="font-display text-[clamp(1.3rem,1.9vw,1.6rem)] leading-[1.15] text-ink">
            {m.data.loopSteps.join(" → ")}
          </p>
        </section>

        <!-- OUTPUT -->
        <section class="border-b border-line px-5 py-5">
          <p class={`font-mono text-[10px] tracking-[0.28em] uppercase text-${m.accent} mb-2`}>▍ Output</p>
          <p class="font-display italic text-[clamp(1.4rem,2.2vw,1.9rem)] leading-[1.05] text-ink">
            {m.data.punchline}
          </p>
        </section>

        <!-- PATCH (compact summary) -->
        <section class="px-5 py-5">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint mb-2">▍ Patch · {m.n}</p>
          <p class="font-mono text-[12px] leading-[1.5]">
            <span class="text-flag">×</span> <span class="line-through decoration-flag/60 text-ink-dim">{m.data.categoryPatch[0].replace(/^.*?:\s*/, "").replace(/\.$/, "")}</span><br />
            <span class={`text-${m.accent}`}>+</span> <span class="text-ink">{m.data.categoryPatch[1].replace(/\.$/, "")}</span>
          </p>
        </section>

        <!-- CTA dock -->
        <section class="mt-auto px-5 py-5 border-t border-line bg-bg-soft/40">
          <a
            href={m.data.href!}
            target="_blank"
            rel="noopener"
            class={`group inline-flex items-center justify-between w-full px-4 py-3 border border-${m.accent}/40 text-ink hover:bg-${m.accent}/10 hover:border-${m.accent} transition-colors font-mono text-[11px] tracking-[0.22em] uppercase`}
          >
            <span class="flex items-center gap-2.5">
              <span aria-hidden="true" class={`block w-2 h-2 rounded-full bg-${m.accent} shadow-[0_0_8px_currentColor] text-${m.accent}`} style="animation: blink-soft 1.6s infinite;"></span>
              <span>Open {m.brand}</span>
            </span>
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
          </a>
        </section>
      </div>
    ))}
  </aside>

  <!-- ─── DOCK ─── -->
  <footer class="console-dock relative border-t border-line bg-bg-soft/40">
    <div class="px-5 sm:px-8 py-3 sm:py-4 flex flex-wrap items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase">
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2 text-ink-dim">
        <li><a href="#manifest" class="hover:text-ink transition-colors">Manifest</a></li>
        <li aria-hidden="true" class="text-ink-faint/60">·</li>
        <li><a href="#failure" class="hover:text-flag transition-colors">Failure report</a></li>
        <li aria-hidden="true" class="text-ink-faint/60">·</li>
        <li><a href="#plate" class="hover:text-ink transition-colors">Publisher plate</a></li>
        <li aria-hidden="true" class="text-ink-faint/60">·</li>
        <li><a href="/legal" class="hover:text-ink transition-colors">Legal ↗</a></li>
      </ul>
      <p class="text-ink-faint">© 2026 Cybird Consulting</p>
    </div>
  </footer>
</form>
