---
import { apps } from "../data/apps.ts";
import { site } from "../data/site.ts";
import RadarArtifact from "./artifacts/RadarArtifact.astro";
import CircleArtifact from "./artifacts/CircleArtifact.astro";
import RaceArtifact from "./artifacts/RaceArtifact.astro";

const bzzt = apps.find((a) => a.id === "bzzt")!;
const cmok = apps.find((a) => a.id === "cmok")!;
const nwd  = apps.find((a) => a.id === "nwd")!;

const meta = [
  { id: "bzzt", n: "01", cat: "Proximity",  appLabel: "BZZT", brand: "BZZT",  brandClass: "font-mono font-bold uppercase tracking-tight",     accent: "bzzt", data: bzzt },
  { id: "cmok", n: "02", cat: "Reassurance",appLabel: "cmok", brand: "cmok", brandClass: "font-display italic lowercase",                     accent: "cmok", data: cmok },
  { id: "nwd",  n: "03", cat: "Gravity",    appLabel: "NWD",  brand: "NWD",  brandClass: "font-display tracking-[-0.02em]",                  accent: "nwd",  data: nwd  },
];
---

<form class="console" aria-label="SWA loop console">

  <!-- ─── radio inputs (CSS-only state) ─── -->
  <input type="radio" name="loop" id="loop-bzzt" class="console-state" checked aria-label="Loop 01 — BZZT, proximity" />
  <input type="radio" name="loop" id="loop-cmok" class="console-state" aria-label="Loop 02 — cmok, reassurance" />
  <input type="radio" name="loop" id="loop-nwd"  class="console-state" aria-label="Loop 03 — NWD, gravity" />

  <!-- ─── TOP STRIP ─── -->
  <header class="console-top relative border-b border-line">
    <span class="absolute top-3 left-3 reg-cross" aria-hidden="true"></span>
    <span class="absolute top-3 right-3 reg-cross" aria-hidden="true"></span>

    <div class="px-5 sm:px-8 py-3 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]"></span>
        SWA.OS · v.2026
      </span>
      <span class="hidden md:inline">3 strange loops detected · status · live</span>
      <span class="text-right">Warsaw · 2026</span>
    </div>
  </header>

  <!-- ─── LEFT: SELECTOR + BRAND ─── -->
  <aside class="console-select border-r border-line lg:flex flex-col">
    <!-- brand -->
    <div class="px-5 sm:px-8 py-6 sm:py-8 border-b border-line">
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint mb-3">▍ Publisher</p>
      <p class="font-display tracking-[-0.04em] leading-[0.85]">
        <span class="block text-[clamp(2.4rem,5vw,3.6rem)] text-ink">Small</span>
        <span class="block text-[clamp(2.4rem,5vw,3.6rem)] italic text-bzzt -mt-1">weird</span>
        <span class="block text-[clamp(2.4rem,5vw,3.6rem)] text-ink -mt-1">Apps<span class="text-bzzt">.</span></span>
      </p>
    </div>

    <!-- selector -->
    <nav aria-label="Select loop" class="px-5 sm:px-8 py-6 sm:py-8 flex-1">
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint mb-5">▍ Select loop</p>

      <ul class="space-y-3">
        {meta.map((m) => (
          <li>
            <label
              for={`loop-${m.id}`}
              data-loop-btn={m.id}
              class="loop-btn group p-3.5 sm:p-4 rounded-sm hover:border-line"
            >
              <span class="flex items-baseline justify-between gap-3 mb-2">
                <span class={`font-mono text-[11px] tracking-[0.22em] text-${m.accent}`}>[{m.n}]</span>
                <span class={`${m.brandClass} text-xl text-ink`}>{m.brand}</span>
              </span>
              <span class="block font-mono font-bold tracking-[0.18em] uppercase text-[12px] text-ink mb-1">
                {m.cat}
              </span>
              <span class="block font-display italic text-[15px] leading-snug text-ink-dim">
                {m.data.taglinePl}
              </span>
            </label>
          </li>
        ))}
      </ul>
    </nav>

    <!-- bottom: manifesto line -->
    <div class="px-5 sm:px-8 py-6 sm:py-8 border-t border-line">
      <p class="font-display text-[clamp(1.2rem,1.8vw,1.4rem)] leading-[1.15] text-ink">
        Real problems.
        <span class="block italic text-ink-dim">Strange little loops.</span>
      </p>
    </div>
  </aside>

  <!-- ─── CENTER: ACTIVE ARTIFACT ─── -->
  <section class="console-artifact relative border-r border-line min-h-[60svh] lg:min-h-0 flex flex-col">

    <!-- artifact bar -->
    <div class="border-b border-line px-5 sm:px-8 py-3 font-mono text-[10px] tracking-[0.28em] uppercase">
      {meta.map((m) => (
        <span
          data-loop={m.id}
          style="--slot-d: flex"
          class={`items-center justify-between w-full text-${m.accent}/80`}
        >
          <span>▍ Machine {m.n} · {m.cat}</span>
          <span class="hidden md:inline">
            <span class={`text-${m.accent}`}>●</span>
            {m.id === "bzzt" && " status · live · scanning"}
            {m.id === "cmok" && " status · ok sent"}
            {m.id === "nwd"  && " status · gate armed"}
          </span>
          <span>{m.id === "bzzt" ? "30 min" : m.id === "cmok" ? "~ 2 sec" : "verified"} ▌</span>
        </span>
      ))}
    </div>

    <!-- giant brand wordmark + artifact -->
    <div class="flex-1 px-5 sm:px-8 py-8 sm:py-12 flex flex-col gap-8 justify-between">

      <!-- machine wordmark -->
      <div class="flex items-baseline gap-6">
        {meta.map((m) => (
          <span data-loop={m.id} class="block">
            <span class={`block ${m.brandClass} text-[clamp(4rem,11vw,11rem)] leading-[0.85] text-${m.accent}`}>
              {m.brand}<span class="text-ink">.</span>
            </span>
            <span class="block mt-2 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
              {m.data.fullName}
            </span>
          </span>
        ))}
      </div>

      <!-- the artifact itself -->
      <div class="relative flex-1 flex items-center justify-center min-h-[40svh] py-4">
        <div data-loop="bzzt" class="w-full max-w-lg"><RadarArtifact /></div>
        <div data-loop="cmok" class="w-full max-w-lg"><CircleArtifact /></div>
        <div data-loop="nwd"  class="w-full max-w-lg"><RaceArtifact /></div>
      </div>

      <!-- tagline -->
      <div>
        {meta.map((m) => (
          <p data-loop={m.id} class="font-display italic text-[clamp(1.4rem,2.4vw,2rem)] leading-[1.1] text-ink">
            {m.data.taglinePl}
            <span class="block mt-1 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint not-italic">
              en · {m.data.tagline}
            </span>
          </p>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── RIGHT: ACTIVE LOOP DETAILS ─── -->
  <aside class="console-details flex flex-col">

    {meta.map((m) => (
      <div data-loop={m.id} style="--slot-d: flex" class="flex-1 flex-col">

        <!-- INPUT block -->
        <section class="border-b border-line px-5 sm:px-7 py-6 sm:py-7">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-flag mb-3">▍ Input</p>
          <ul class="space-y-1.5">
            {m.data.input.map((line) => (
              <li class="font-display text-[clamp(1.4rem,2.2vw,1.7rem)] leading-[1.1] text-ink">
                <span class="text-flag mr-2 align-middle">×</span>
                <span class="line-through decoration-flag/80 decoration-2 italic text-ink-dim">{line}</span>
              </li>
            ))}
          </ul>
        </section>

        <!-- CATEGORY DEFAULT loop -->
        <section class="border-b border-line px-5 sm:px-7 py-6 sm:py-7">
          <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint mb-3">▍ Category default</p>
          <p class="font-display text-[clamp(1.2rem,1.9vw,1.5rem)] leading-[1.2] text-ink-dim line-through decoration-flag/60 decoration-1">
            {m.data.categoryDefault.join(" → ")}
          </p>
        </section>

        <!-- LOOP CORE — the SWA mutation -->
        <section class={`border-b border-line px-5 sm:px-7 py-6 sm:py-7 bg-${m.accent}/[0.04]`}>
          <div class="flex items-baseline justify-between mb-3">
            <p class={`font-mono text-[10px] tracking-[0.28em] uppercase text-${m.accent}`}>▍ Loop core · SWA mutation</p>
            <span class={`font-mono text-[9px] tracking-[0.22em] uppercase text-${m.accent}/70`}>↺ repeat</span>
          </div>
          <ol class="space-y-1">
            {m.data.loopSteps.map((step, i) => (
              <li class="flex items-baseline gap-3 font-display text-[clamp(1.4rem,2.2vw,1.7rem)] text-ink">
                <span class={`font-mono text-[10px] tracking-[0.18em] text-${m.accent}/70 w-5`}>0{i + 1}</span>
                <span>{step}</span>
                <span class={`font-mono text-[9px] tracking-[0.18em] uppercase text-${m.accent}/50 ml-auto`}>{m.data.loopStepsPl[i]}</span>
              </li>
            ))}
          </ol>
        </section>

        <!-- OUTPUT block -->
        <section class="px-5 sm:px-7 py-6 sm:py-7 flex-1 flex flex-col justify-between gap-6">
          <div>
            <p class={`font-mono text-[10px] tracking-[0.28em] uppercase text-${m.accent} mb-3`}>▍ Output</p>
            <p class="font-display italic text-[clamp(1.5rem,2.4vw,2rem)] leading-[1.05] text-ink">
              {m.data.punchline}
            </p>
          </div>

          <a
            href={m.data.href!}
            target="_blank"
            rel="noopener"
            class={`group inline-flex items-center gap-3 self-start mt-2 px-4 py-3 border border-${m.accent}/40 text-ink hover:bg-${m.accent}/10 hover:border-${m.accent} transition-colors font-mono text-[11px] tracking-[0.22em] uppercase`}
          >
            <span aria-hidden="true" class={`block w-2 h-2 rounded-full bg-${m.accent} shadow-[0_0_8px_currentColor] text-${m.accent}`}></span>
            <span>Open {m.brand}</span>
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
          </a>
        </section>
      </div>
    ))}
  </aside>

  <!-- ─── DOCK ─── -->
  <footer class="console-dock relative border-t border-line bg-bg-soft/40">
    <div class="px-5 sm:px-8 py-3 sm:py-4 flex flex-wrap items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase">

      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-ink-dim">
        <li>
          <a href="#manifest" class="inline-flex items-center gap-1.5 hover:text-ink transition-colors">
            <span aria-hidden="true">▍</span> Manifest
          </a>
        </li>
        <li>
          <a href="#failure" class="inline-flex items-center gap-1.5 hover:text-flag transition-colors">
            <span aria-hidden="true">▍</span> Category failure report
          </a>
        </li>
        <li>
          <a href="#plate" class="inline-flex items-center gap-1.5 hover:text-ink transition-colors">
            <span aria-hidden="true">▍</span> Publisher plate
          </a>
        </li>
        <li>
          <a href="/legal" class="inline-flex items-center gap-1.5 hover:text-ink transition-colors">
            <span aria-hidden="true">▍</span> Legal ↗
          </a>
        </li>
      </ul>

      <p class="text-ink-faint">
        © 2026 Cybird Consulting · loop 04 · drafting
      </p>
    </div>
  </footer>
</form>
