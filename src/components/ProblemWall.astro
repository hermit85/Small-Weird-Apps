---
const reports = [
  {
    n: "01",
    cat: "Dating",
    charge: "profile shopping.",
    status: "stale",
    diagnosis: "loop got stuck in browse mode.",
    accent: "bzzt",
  },
  {
    n: "02",
    cat: "Safety",
    charge: "panic theatre.",
    status: "noisy",
    diagnosis: "only fires after the fact.",
    accent: "cmok",
  },
  {
    n: "03",
    cat: "Racing",
    charge: "training log / event dependency.",
    status: "thin",
    diagnosis: "no gravity, no game.",
    accent: "nwd",
  },
] as const;
---

<section class="relative border-t border-line overflow-hidden">

  <!-- subtle slash pattern -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.05]"
    aria-hidden="true"
    style="background-image: repeating-linear-gradient(135deg, transparent 0 30px, var(--color-flag) 30px 31px);"
  ></div>

  <!-- masthead -->
  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-14 sm:py-20">
    <div class="flex items-baseline justify-between gap-4 mb-6">
      <p class="font-mono text-[11px] tracking-[0.32em] uppercase text-flag">▍ Category failure report</p>
      <span aria-hidden="true" class="flex-1 h-px bg-line"></span>
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">filed · 2026</p>
    </div>

    <h2 class="font-display text-[clamp(2.4rem,7vw,5.5rem)] leading-[0.95] tracking-tight text-ink max-w-5xl">
      Three categories
      <span class="italic text-ink-dim">that quietly broke.</span>
    </h2>
  </div>

  <!-- THREE REPORTS — case file format -->
  <ol class="relative">
    {reports.map((r) => (
      <li class="relative border-t border-line">
        <div class="mx-auto max-w-[1600px] px-5 sm:px-8 py-14 sm:py-20">
          <div class="grid grid-cols-12 gap-4 sm:gap-8">

            <!-- left: report header -->
            <header class="col-span-12 md:col-span-3 flex md:flex-col items-baseline md:items-start gap-3 md:gap-2">
              <span class="font-mono text-[11px] tracking-[0.28em] uppercase text-flag">▍ Report</span>
              <span class={`font-display text-[clamp(3.5rem,7vw,6rem)] leading-[0.85] text-${r.accent}`}>
                {r.n}
              </span>
              <span class="font-mono text-[11px] tracking-[0.32em] uppercase text-ink-faint">{r.cat}</span>
            </header>

            <!-- main: structured charge form -->
            <dl class="col-span-12 md:col-span-7 md:col-start-4 grid grid-cols-12 gap-x-4 gap-y-3 items-baseline">
              <dt class="col-span-3 md:col-span-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint pt-3">Charge</dt>
              <dd class="col-span-9 md:col-span-10">
                <p class="font-display italic text-[clamp(2.2rem,7vw,6rem)] leading-[0.96] text-ink">
                  <span class={`text-${r.accent}`}>“</span>{r.charge}<span class={`text-${r.accent}`}>”</span>
                </p>
              </dd>

              <dt class="col-span-3 md:col-span-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint mt-4">Status</dt>
              <dd class="col-span-9 md:col-span-10 mt-4">
                <span class="stamp text-flag uppercase">× {r.status}</span>
              </dd>

              <dt class="col-span-3 md:col-span-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint mt-2">Diagnosis</dt>
              <dd class="col-span-9 md:col-span-10 mt-2 font-display italic text-[clamp(1.2rem,2.4vw,1.6rem)] text-ink-dim">
                {r.diagnosis}
              </dd>
            </dl>

            <!-- right: bug ID -->
            <div class="col-span-12 md:col-span-2 md:col-start-11 md:text-right mt-2 md:mt-0">
              <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
                bug.id<br />
                <span class={`text-${r.accent}`}>{r.cat.toUpperCase()}.{r.n}</span>
              </span>
            </div>
          </div>
        </div>
      </li>
    ))}
  </ol>

  <!-- TRANSITION: REWIRE THE LOOP -->
  <div class="relative border-t border-line bg-bg-soft/60">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-32">
      <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end">
        <div class="col-span-12 md:col-span-2 callout text-ink-faint">
          ▍ Counter
        </div>
        <p class="col-span-12 md:col-span-10 font-display text-[clamp(2.6rem,9.5vw,9rem)] leading-[0.95] tracking-tight text-ink">
          Rewire the loop
          <span aria-hidden="true" class="inline-flex items-baseline gap-3 sm:gap-5 ml-3 sm:ml-5 align-baseline">
            <span class="text-bzzt">→</span>
          </span>
        </p>
      </div>
    </div>
  </div>
</section>
