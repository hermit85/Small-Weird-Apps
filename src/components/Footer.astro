---
import { site } from "../data/site.ts";
const year = new Date().getFullYear();
---

<footer class="relative border-t border-line">
  <div class="mx-auto max-w-[1600px] px-5 sm:px-8 py-12 sm:py-16 grid grid-cols-12 gap-6 sm:gap-10 items-end">

    <div class="col-span-12 md:col-span-7">
      <p class="font-display text-[clamp(1.2rem,2vw,1.6rem)] leading-snug text-ink">
        {site.name} is a product label by <span class="italic">Cybird Consulting</span>.
      </p>
      <p class="mt-1 font-display text-[clamp(1.2rem,2vw,1.6rem)] leading-snug text-ink-dim">
        {site.city}.
      </p>
      <a
        href={`mailto:${site.email}`}
        class="mt-3 inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-dim hover:text-bzzt transition-colors"
      >
        <span>{site.email}</span>
        <span aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="col-span-12 md:col-span-5 md:text-right">
      <a
        href="/legal"
        class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-dim hover:text-ink transition-colors"
      >
        <span>Legal</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="col-span-12 mt-6 pt-4 border-t border-line-soft flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">
      <span>© {year} Cybird Consulting</span>
      <span class="italic font-sans normal-case tracking-normal text-ink-dim">
        The apps are weird. The company details are normal.
      </span>
    </div>
  </div>
</footer>
