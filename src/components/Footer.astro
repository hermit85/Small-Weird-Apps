---
import { site } from "../data/site.ts";
const year = new Date().getFullYear();
---

<footer class="relative border-t-2 border-ink/30 mt-32 overflow-hidden">

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-16 sm:py-20">

    <!-- top status -->
    <div class="flex items-center justify-between mb-12 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]"></span>
        SWA.OS · halt
      </span>
      <span class="hidden md:inline">three loops shipped · loop 04 in draft</span>
      <span>v.2026.04</span>
    </div>

    <!-- centered colophon -->
    <div class="text-center max-w-3xl mx-auto">
      <p class="font-display text-[clamp(1.6rem,3.2vw,2.4rem)] leading-[1.25] text-ink">
        {site.name} is a product label
        <span class="block">owned by <span class="italic">Cybird Consulting Dariusz Ptaszek</span></span>
        <span class="block text-ink-dim">— published from {site.city}.</span>
      </p>

      <div class="mt-10 flex items-center justify-center gap-3 sm:gap-4 callout text-ink-faint flex-wrap">
        <span aria-hidden="true">━━━━━</span>
        <a href="/#apps" class="hover:text-ink transition-colors">Apps</a>
        <span aria-hidden="true">·</span>
        <a href="/#company" class="hover:text-ink transition-colors">Contact</a>
        <span aria-hidden="true">·</span>
        <a href="/legal" class="hover:text-ink transition-colors">Legal</a>
        <span aria-hidden="true">·</span>
        <a href={site.linkedin} target="_blank" rel="noopener" class="hover:text-ink transition-colors">LinkedIn ↗</a>
        <span aria-hidden="true">━━━━━</span>
      </div>
    </div>

    <!-- bottom strip -->
    <div class="mt-16 sm:mt-20 grid grid-cols-12 gap-4 sm:gap-8 items-end border-t border-line pt-8">
      <p class="col-span-6 md:col-span-3 callout text-ink-faint">
        © {year} {site.legalOwner}
      </p>
      <p class="col-span-12 md:col-span-6 md:order-2 text-center font-display italic text-base sm:text-xl text-ink-dim">
        The apps are weird. The company details are normal.
      </p>
      <p class="col-span-6 md:col-span-3 md:order-3 text-right callout text-ink-faint">
        End of file
      </p>
    </div>
  </div>

  <!-- corner registration marks -->
  <span class="absolute bottom-3 left-3 reg-cross" aria-hidden="true"></span>
  <span class="absolute bottom-3 right-3 reg-cross" aria-hidden="true"></span>
</footer>
