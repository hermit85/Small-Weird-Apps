---
const reports = [
  { n: "01", cat: "Dating",  charge: "profile shopping",                 status: "stale", fix: "BZZT", brand: "BZZT", brandClass: "font-mono font-bold uppercase tracking-tight",     accent: "bzzt" },
  { n: "02", cat: "Safety",  charge: "panic theatre",                    status: "noisy", fix: "cmok", brand: "cmok", brandClass: "font-display italic lowercase",                     accent: "cmok" },
  { n: "03", cat: "Racing",  charge: "training log / event dependency",  status: "thin",  fix: "NWD",  brand: "NWD",  brandClass: "font-display tracking-[-0.02em]",                  accent: "nwd"  },
];
---

<aside id="failure" class="overlay" aria-label="Category Failure Report">
  <a href="#" class="overlay-backdrop-link" aria-label="Close failure report"></a>

  <article class="overlay-card noise">
    <a href="#" class="overlay-close">close ×</a>

    <!-- diagonal slash pattern in background -->
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.05]"
      aria-hidden="true"
      style="background-image: repeating-linear-gradient(135deg, transparent 0 30px, var(--color-flag) 30px 31px);"
    ></div>

    <div class="relative">
      <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-flag mb-3">▍ Category failure report</p>

      <h2 class="font-display text-[clamp(2.4rem,6.5vw,4rem)] leading-[0.95] text-ink mb-2">
        Three categories
        <span class="italic text-ink-dim">that quietly broke.</span>
      </h2>
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">filed · 2026</p>

      <ol class="mt-10 divide-y divide-line border-y border-line">
        {reports.map((r) => (
          <li class="grid grid-cols-12 gap-4 py-6 items-baseline">
            <header class="col-span-12 md:col-span-2">
              <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-flag">▍ {r.n}</p>
              <p class={`font-display text-3xl mt-1 text-${r.accent}`}>{r.cat}</p>
            </header>

            <dl class="col-span-12 md:col-span-7 grid grid-cols-12 gap-x-3 gap-y-2 items-baseline">
              <dt class="col-span-3 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Charge</dt>
              <dd class="col-span-9 font-display italic text-[clamp(1.4rem,3vw,2rem)] leading-[1] text-ink">
                <span class={`text-${r.accent}`}>“</span>{r.charge}<span class={`text-${r.accent}`}>”</span>
              </dd>

              <dt class="col-span-3 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Status</dt>
              <dd class="col-span-9">
                <span class="stamp text-flag uppercase">× {r.status}</span>
              </dd>
            </dl>

            <div class="col-span-12 md:col-span-3 md:text-right">
              <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint mb-1">▍ Fix</p>
              <p class={`${r.brandClass} text-2xl text-${r.accent}`}>{r.brand}</p>
            </div>
          </li>
        ))}
      </ol>

      <p class="mt-12 font-display italic text-[clamp(1.6rem,3vw,2.2rem)] text-ink-dim">
        So we changed the loop.
        <span aria-hidden="true" class="not-italic text-ink-faint font-mono text-[11px] tracking-[0.22em] uppercase ml-3">↗ select a machine</span>
      </p>
    </div>
  </article>
</aside>
