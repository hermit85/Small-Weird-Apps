---
import { site } from "../../data/site.ts";
---

<aside id="plate" class="overlay" aria-label="Publisher plate">
  <a href="#" class="overlay-backdrop-link" aria-label="Close publisher plate"></a>

  <article class="overlay-card">
    <a href="#" class="overlay-close">close ×</a>

    <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink mb-8">▍ Publisher plate</p>

    <!-- the plate itself -->
    <div class="relative grid grid-cols-12 gap-0 border-2 border-ink/40 bg-bg-soft/40">
      <div class="hidden md:flex md:col-span-1 flex-col items-center justify-between border-r border-dashed border-ink/30 py-7">
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-ink-faint/70"></span>
        <span class="callout text-ink-faint" style="writing-mode: vertical-rl; transform: rotate(180deg);">
          Publisher · plate
        </span>
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-ink-faint/70"></span>
      </div>

      <dl class="col-span-12 md:col-span-11 divide-y divide-ink/15">
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Label</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl text-ink">{site.name}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Owner</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl text-ink">{site.legalOwner}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Base</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl text-ink">{site.city}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Contact</dt>
          <dd class="col-span-8 md:col-span-9">
            <a
              href={`mailto:${site.email}`}
              class="group inline-flex items-center gap-2 font-display text-xl sm:text-2xl text-ink hover:text-bzzt transition-colors break-all"
            >
              {site.email}
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">↗</span>
            </a>
          </dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Record</dt>
          <dd class="col-span-8 md:col-span-9">
            <a href="/legal" class="group inline-flex items-center gap-2 font-display italic text-xl text-ink hover:text-bzzt transition-colors">
              Legal page
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">→</span>
            </a>
          </dd>
        </div>
      </dl>
    </div>

    <!-- catalogue under the plate -->
    <div class="mt-8 grid grid-cols-12 gap-4 items-baseline">
      <p class="col-span-12 md:col-span-3 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">▍ Catalogue · current</p>
      <ul class="col-span-12 md:col-span-9 divide-y divide-line">
        <li class="grid grid-cols-12 gap-3 py-3 items-baseline">
          <span class="col-span-2 font-mono text-[10px] tracking-[0.22em] uppercase text-bzzt/70">M.01</span>
          <span class="col-span-4 font-mono font-bold uppercase tracking-tight text-xl text-ink">BZZT</span>
          <span class="col-span-4 text-ink-dim text-sm">A radar for people. Here and now.</span>
          <a class="col-span-2 text-right callout text-ink hover:text-bzzt transition-colors" href="https://apps.apple.com/pl/app/bzzt-zone/id6760717645?l=pl" target="_blank" rel="noopener">App Store ↗</a>
        </li>
        <li class="grid grid-cols-12 gap-3 py-3 items-baseline">
          <span class="col-span-2 font-mono text-[10px] tracking-[0.22em] uppercase text-cmok/70">M.02</span>
          <span class="col-span-4 font-display italic lowercase text-2xl text-ink">cmok</span>
          <span class="col-span-4 text-ink-dim text-sm">A daily sign that everything is OK.</span>
          <a class="col-span-2 text-right callout text-ink hover:text-cmok transition-colors" href="https://apps.apple.com/pl/app/cmok/id6762090888" target="_blank" rel="noopener">App Store ↗</a>
        </li>
        <li class="grid grid-cols-12 gap-3 py-3 items-baseline">
          <span class="col-span-2 font-mono text-[10px] tracking-[0.22em] uppercase text-nwd/70">M.03</span>
          <span class="col-span-4 font-display tracking-[-0.02em] text-2xl text-ink">NWD</span>
          <span class="col-span-4 text-ink-dim text-sm">Gravity MTB league. Verified.</span>
          <a class="col-span-2 text-right callout text-ink hover:text-nwd transition-colors" href="https://new-world-disorder.vercel.app/" target="_blank" rel="noopener">Open ↗</a>
        </li>
        <li class="grid grid-cols-12 gap-3 py-3 items-baseline opacity-60">
          <span class="col-span-2 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">M.04</span>
          <span class="col-span-4 font-display italic text-xl text-ink-dim">unassigned</span>
          <span class="col-span-4 text-ink-faint text-sm">in workshop · drafting</span>
          <span class="col-span-2 text-right callout text-ink-faint">soon</span>
        </li>
      </ul>
    </div>
  </article>
</aside>
