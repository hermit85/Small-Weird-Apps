---
---

<aside id="manifest" class="overlay" aria-label="Manifest">
  <a href="#" class="overlay-backdrop-link" aria-label="Close manifest"></a>

  <article class="overlay-card noise">
    <a href="#" class="overlay-close">close ×</a>

    <p class="font-mono text-[10px] tracking-[0.32em] uppercase text-ink mb-8">▍ Manifest</p>

    <h2 class="font-display text-[clamp(2.4rem,7vw,4.5rem)] leading-[0.95] text-ink">
      These are
      <span class="italic text-ink-dim">small apps.</span>
    </h2>

    <ul class="mt-10 space-y-3 font-display text-[clamp(1.4rem,3.2vw,2.2rem)] leading-[1.1]">
      <li class="flex items-baseline gap-3 text-ink-dim">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
        <span class="line-through decoration-flag/70 decoration-2">Not platforms.</span>
      </li>
      <li class="flex items-baseline gap-3 text-ink-dim">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
        <span class="line-through decoration-flag/70 decoration-2">Not feeds.</span>
      </li>
      <li class="flex items-baseline gap-3 text-ink-dim">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
        <span class="line-through decoration-flag/70 decoration-2">Not productivity empires.</span>
      </li>
    </ul>

    <p class="mt-12 font-display text-[clamp(1.8rem,4.5vw,3rem)] leading-[1.05] text-ink">
      Just little loops
      <span class="block italic text-ink-dim">for real moments:</span>
    </p>

    <ul class="mt-6 space-y-2 font-display text-[clamp(1.4rem,2.8vw,2rem)]">
      <li class="flex items-baseline gap-4 text-ink">
        <span class="font-mono text-[10px] tracking-[0.22em] text-bzzt w-5">01</span>
        <span class="italic">a signal,</span>
      </li>
      <li class="flex items-baseline gap-4 text-ink">
        <span class="font-mono text-[10px] tracking-[0.22em] text-cmok w-5">02</span>
        <span class="italic">a check-in,</span>
      </li>
      <li class="flex items-baseline gap-4 text-ink">
        <span class="font-mono text-[10px] tracking-[0.22em] text-nwd w-5">03</span>
        <span class="italic">a race.</span>
      </li>
    </ul>

    <div class="mt-12 inline-flex items-center gap-4 px-6 py-4 border border-ink/40 text-ink rounded-full">
      <span class="font-display italic text-[clamp(1.2rem,2.4vw,1.6rem)]">Useful.</span>
      <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-bzzt shadow-[0_0_10px_var(--color-bzzt)]"></span>
      <span class="font-display italic text-[clamp(1.2rem,2.4vw,1.6rem)]">Strange.</span>
      <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-cmok shadow-[0_0_10px_var(--color-cmok)]"></span>
      <span class="font-display italic text-[clamp(1.2rem,2.4vw,1.6rem)]">Nicely made.</span>
    </div>
  </article>
</aside>
