---
import { apps } from "../../data/apps.ts";
const app = apps.find((a) => a.id === "nwd")!;

const leaderboard = [
  { rank: 1, tag: "MTB.LD7", time: "01:38.42", delta: "leader" },
  { rank: 2, tag: "GATE_K", time: "01:39.07", delta: "+0.65" },
  { rank: 3, tag: "DRT.PL", time: "01:41.18", delta: "+2.76" },
  { rank: 4, tag: "RUN_3", time: "01:43.29", delta: "+4.87" },
];
---

<section
  id="nwd"
  class="relative isolate overflow-hidden border-t border-line scroll-mt-20 world-nwd noise"
>
  <!-- archive bar -->
  <div class="relative border-b border-line py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-nwd/80">
      <span>▍ Machine 03 / Gate · Racing</span>
      <span class="hidden md:inline">trail · WAS-001 / gates · armed / mode · league</span>
      <span>NWD.003 ▌</span>
    </div>
  </div>

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-32">

    <!-- header -->
    <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end">
      <h2 class="col-span-12 md:col-span-8 font-display tracking-[-0.05em] leading-[0.82] select-none">
        <span class="block text-[clamp(5rem,22vw,22rem)] text-nwd">
          NWD<span class="text-ink">.</span>
        </span>
      </h2>
      <p class="col-span-12 md:col-span-4 font-display italic text-[clamp(1.6rem,3.2vw,2.4rem)] leading-[1.05] text-ink md:pb-6">
        {app.tagline}
      </p>
    </div>

    <!-- intro line -->
    <p class="mt-4 sm:mt-8 max-w-2xl text-base sm:text-lg text-ink-dim leading-relaxed">
      <span>{app.intro[0]}</span>
      <span class="block text-ink">{app.intro[1]}</span>
    </p>

    <!-- ─── LOOP MACHINE ─── -->
    <div class="relative mt-20 sm:mt-32 grid grid-cols-12 gap-4 sm:gap-8 items-stretch">

      <!-- INPUT -->
      <div class="col-span-12 md:col-span-3 flex flex-col justify-between gap-8 md:border-r border-nwd/15 md:pr-6">
        <div>
          <p class="callout text-flag mb-4">▍ Input</p>
          <p class="font-display text-[clamp(2rem,4.5vw,3rem)] leading-[1] text-ink">
            <span class="text-flag mr-2 align-middle text-2xl">×</span>
            <span class="line-through decoration-flag/80 decoration-2 italic text-ink-dim">training log</span>
          </p>
          <p class="mt-3 font-display text-[clamp(2rem,4.5vw,3rem)] leading-[1] text-ink">
            <span class="text-flag mr-2 align-middle text-2xl">×</span>
            <span class="line-through decoration-flag/80 decoration-2 italic text-ink-dim">event calendar</span>
          </p>
        </div>

        <ul class="hidden md:block space-y-1 callout text-ink-faint">
          {app.bullets.map((b) => (
            <li class="flex items-baseline gap-2">
              <span aria-hidden="true">·</span>
              <span class="text-ink-dim normal-case tracking-normal font-sans text-sm italic">{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- arrow -->
      <div class="hidden md:flex md:col-span-1 items-center justify-center text-nwd/50" aria-hidden="true">
        <span class="text-3xl">→</span>
      </div>

      <!-- LOOP — race-track flow with return arc + timer + leaderboard -->
      <div class="col-span-12 md:col-span-5 relative flex flex-col gap-6 md:gap-8">
        <p class="callout text-nwd">▍ Loop · live</p>

        <!-- horizontal flow with loop-back arc -->
        <div class="relative pt-2 pb-12">
          <ol class="flex items-center justify-between font-mono text-[11px] tracking-[0.18em] uppercase">
            {app.loopSteps.map((step, i) => (
              <Fragment>
                <li class="flex flex-col items-center gap-2 relative z-10">
                  <span class="block w-3 h-3 rounded-full bg-nwd shadow-[0_0_12px_var(--color-nwd)]" style={`animation: blink-soft ${2 + i * 0.3}s ease-in-out ${i * 0.2}s infinite;`}></span>
                  <span class="text-nwd whitespace-nowrap">{step}</span>
                  <span class="text-ink-faint text-[9px]">0{i + 1}</span>
                </li>
                {i < app.loopSteps.length - 1 && (
                  <li aria-hidden="true" class="flex-1 mx-1 border-t border-dashed border-nwd/40 mb-7"></li>
                )}
              </Fragment>
            ))}
          </ol>

          <!-- return arc (goes from last item back to first, below the row) -->
          <svg
            aria-hidden="true"
            class="absolute left-0 right-0 -bottom-2 w-full h-12 text-nwd/55 overflow-visible"
            viewBox="0 0 100 14"
            preserveAspectRatio="none"
          >
            <path
              d="M 98 0 C 95 14, 5 14, 2 0"
              stroke="currentColor"
              stroke-width="0.6"
              stroke-dasharray="0.8 1.2"
              fill="none"
              vector-effect="non-scaling-stroke"
            />
            <polygon
              points="2,0 5,2 5,-2"
              fill="currentColor"
              vector-effect="non-scaling-stroke"
            />
          </svg>
        </div>

        <!-- TIMER + leaderboard, anchored to the loop -->
        <div class="grid grid-cols-12 gap-4 mt-4 items-end">
          <div class="col-span-7">
            <p class="callout text-nwd/70 mb-2">▍ Time · live</p>
            <p
              class="font-mono font-medium text-nwd leading-none tracking-[-0.04em] tabular-nums"
              style="font-size: clamp(3rem, 9vw, 7rem); animation: timer 1.4s ease-in-out infinite;"
            >01:42<span class="text-nwd/70">.</span>07</p>
          </div>
          <ol class="col-span-5 font-mono text-[11px] text-ink divide-y divide-nwd/15 border-y border-nwd/30">
            {leaderboard.map((row) => (
              <li class={`flex items-center justify-between py-1.5 ${row.rank === 1 ? "text-nwd" : "text-ink-dim"}`}>
                <span class="flex items-center gap-2">
                  <span class="tabular-nums w-4 text-right">{String(row.rank).padStart(2, "0")}</span>
                  <span>{row.tag}</span>
                </span>
                <span class="tabular-nums">{row.time}</span>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <!-- arrow -->
      <div class="hidden md:flex md:col-span-1 items-center justify-center text-nwd/50" aria-hidden="true">
        <span class="text-3xl">→</span>
      </div>

      <!-- OUTPUT -->
      <div class="col-span-12 md:col-span-2 flex flex-col justify-between gap-8 md:border-l border-nwd/15 md:pl-6">
        <div>
          <p class="callout text-nwd mb-4">▍ Output</p>
          <p class="font-display italic text-[clamp(1.8rem,3vw,2.4rem)] leading-[1.05] text-ink">
            {app.punchline}
          </p>
        </div>

        <a
          href={app.href!}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-2 callout text-ink hover:text-nwd transition-colors"
        >
          <span aria-hidden="true" class="block w-8 dim-line text-ink-faint group-hover:text-nwd transition-colors"></span>
          <span>Open NWD</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
        </a>
      </div>
    </div>
  </div>

  <!-- bottom strip -->
  <div class="relative border-t border-nwd/20 py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-nwd/50">
      <span>▍ End machine 03</span>
      <span class="hidden md:inline">— continue manifest —</span>
      <span>↓ ▌</span>
    </div>
  </div>
</section>
