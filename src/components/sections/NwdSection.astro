---
import { apps } from "../../data/apps.ts";
const app = apps.find((a) => a.id === "nwd")!;

const leaderboard = [
  { rank: 1, tag: "MTB.LD7", time: "01:38.42", delta: "leader" },
  { rank: 2, tag: "GATE_K", time: "01:39.07", delta: "+0.65" },
  { rank: 3, tag: "DRT.PL", time: "01:41.18", delta: "+2.76" },
  { rank: 4, tag: "—", time: "01:43.29", delta: "+4.87" },
  { rank: 5, tag: "RUN_3", time: "01:44.51", delta: "+6.09" },
];
---

<section
  id="nwd"
  class="relative isolate overflow-hidden border-t border-line scroll-mt-20 world-nwd noise"
>
  <!-- archive bar -->
  <div class="relative border-b border-line py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-nwd/80">
      <span>▍ Exhibit 03 · Machine 03 / Gate</span>
      <span class="hidden md:inline">trail · WAS-001 / gates · armed / mode · league</span>
      <span>NWD.003 ▌</span>
    </div>
  </div>

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-32">

    <!-- letterspaced wide wordmark -->
    <h2 class="font-display tracking-[-0.05em] leading-[0.82] select-none flex items-baseline gap-[2vw]">
      <span class="text-[clamp(5rem,22vw,22rem)] text-nwd">NWD<span class="text-ink">.</span></span>
      <span aria-hidden="true" class="hidden md:inline-block flex-1 h-1 bg-nwd/40"></span>
      <span aria-hidden="true" class="hidden md:inline-block callout text-nwd/70">league · live</span>
    </h2>

    <p class="mt-2 sm:mt-4 font-display italic text-[clamp(1.6rem,4vw,2.8rem)] leading-[1.05] text-ink">
      {app.tagline}
    </p>

    <!-- TIMER + COLUMNS -->
    <div class="mt-16 sm:mt-24 grid grid-cols-12 gap-4 sm:gap-8 items-start">

      <!-- left: schematic gate -->
      <div class="col-span-12 md:col-span-3 self-center">
        <p class="callout text-nwd/80 mb-4">▍ Gate · armed</p>
        <svg viewBox="0 0 200 200" class="w-40 sm:w-full max-w-[14rem] text-nwd" aria-hidden="true">
          <defs>
            <pattern id="hatch-nwd" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(45)">
              <line x1="0" y1="0" x2="0" y2="6" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.5"/>
            </pattern>
          </defs>
          <!-- gate posts -->
          <rect x="22" y="40" width="14" height="120" fill="url(#hatch-nwd)" stroke="currentColor" />
          <rect x="164" y="40" width="14" height="120" fill="url(#hatch-nwd)" stroke="currentColor" />
          <!-- arrow through -->
          <line x1="40" y1="100" x2="160" y2="100" stroke="currentColor" stroke-width="2" stroke-dasharray="6 4"/>
          <polygon points="160,100 150,94 150,106" fill="currentColor" />
          <!-- dim labels -->
          <g font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.18em" fill="currentColor" fill-opacity="0.6">
            <text x="100" y="180" text-anchor="middle">RIDE THROUGH</text>
            <text x="100" y="34" text-anchor="middle">A · B</text>
          </g>
        </svg>
      </div>

      <!-- center: TIMER -->
      <div class="col-span-12 md:col-span-6 text-center md:text-left relative">
        <p class="callout text-nwd/80 mb-3">▍ Live time</p>
        <p
          class="font-mono font-medium text-nwd leading-none tracking-[-0.04em] tabular-nums"
          style="font-size: clamp(4.5rem, 18vw, 14rem); animation: timer 1.4s ease-in-out infinite;"
        >
          01:42<span class="text-nwd/70">.</span>07
        </p>
        <div class="mt-4 flex items-center justify-center md:justify-start gap-3 callout text-nwd/60">
          <span class="block w-10 dim-line text-nwd/40"></span>
          <span>Loop 03 · gate A → B</span>
          <span class="block w-10 dim-line text-nwd/40"></span>
        </div>
      </div>

      <!-- right: leaderboard, terminal style -->
      <div class="col-span-12 md:col-span-3">
        <p class="callout text-nwd/80 mb-4">▍ Leaderboard</p>
        <ol class="font-mono text-[12px] text-ink divide-y divide-nwd/15 border-y border-nwd/30">
          {leaderboard.map((row) => (
            <li class={`flex items-center justify-between py-2 ${row.rank === 1 ? "text-nwd" : row.rank > 3 ? "text-ink-faint" : "text-ink-dim"}`}>
              <span class="flex items-center gap-3">
                <span class="tabular-nums w-4 text-right">{String(row.rank).padStart(2, "0")}</span>
                <span>{row.tag}</span>
              </span>
              <span class="flex items-center gap-3">
                <span class="text-[10px] uppercase tracking-[0.18em] opacity-60">{row.delta}</span>
                <span class="tabular-nums">{row.time}</span>
              </span>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- copy: bullets as race steps -->
    <div class="mt-20 sm:mt-28 grid grid-cols-12 gap-4 sm:gap-8 items-baseline">
      <div class="col-span-12 md:col-span-5">
        <p class="callout text-nwd/80 mb-4">▍ Premise</p>
        <div class="space-y-2 font-display text-[clamp(1.6rem,3.2vw,2.4rem)] leading-[1.1] text-ink">
          {app.intro.map((line) => <p>{line}</p>)}
        </div>
      </div>

      <!-- the loop steps as a horizontal flow -->
      <ol class="col-span-12 md:col-span-7 flex flex-wrap items-center gap-x-4 gap-y-3 font-display text-[clamp(1.4rem,2.6vw,2rem)] text-ink">
        {app.bullets.map((b, i) => (
          <li class="flex items-baseline gap-3">
            <span class="font-mono text-[10px] tracking-[0.18em] text-nwd/70">{`0${i + 1}`}</span>
            <span>{b}</span>
            {i < app.bullets.length - 1 && (
              <span aria-hidden="true" class="text-nwd/50 text-base">→</span>
            )}
          </li>
        ))}
      </ol>
    </div>

    <!-- punchline + CTA -->
    <div class="mt-20 sm:mt-28 grid grid-cols-12 gap-4 sm:gap-8 items-end border-t border-nwd/20 pt-10">
      <p class="col-span-12 md:col-span-7 font-display italic text-[clamp(1.8rem,4.5vw,3.2rem)] leading-[1.05] text-ink">
        {app.punchline}
      </p>
      <div class="col-span-12 md:col-span-5 md:text-right flex md:justify-end">
        <a
          href={app.href!}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 callout text-ink hover:text-nwd transition-colors"
        >
          <span aria-hidden="true" class="block w-12 dim-line text-ink-faint group-hover:text-nwd transition-colors"></span>
          <span>Open NWD</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
        </a>
      </div>
    </div>
  </div>

  <!-- bottom strip -->
  <div class="relative border-t border-nwd/20 py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-nwd/50">
      <span>▍ End exhibit 03</span>
      <span class="hidden md:inline">— continue manifest —</span>
      <span>↓ ▌</span>
    </div>
  </div>
</section>
