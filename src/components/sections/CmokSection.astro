---
import { apps } from "../../data/apps.ts";
const app = apps.find((a) => a.id === "cmok")!;

// 3 step labels at 12 / 4 / 8 o'clock around the close circle
const labelRadius = 250;
const cx = 300;
const cy = 300;
const stepPositions = app.loopSteps.map((label, i) => {
  const pl = app.loopStepsPl[i];
  const angleDeg = -90 + i * 120;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    label,
    pl,
    x: cx + labelRadius * Math.cos(angleRad),
    y: cy + labelRadius * Math.sin(angleRad),
    angleDeg,
  };
});

// inner close-circle of "people" — small, intimate (7 dots)
const peopleCount = 7;
const peopleRadius = 150;
const people = Array.from({ length: peopleCount }, (_, i) => {
  const angleDeg = -90 + (360 / peopleCount) * i;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    x: cx + peopleRadius * Math.cos(angleRad),
    y: cy + peopleRadius * Math.sin(angleRad),
    delay: (i * 0.4).toFixed(2),
  };
});
---

<section
  id="cmok"
  class="relative isolate overflow-hidden border-t border-line scroll-mt-20 world-cmok noise"
>
  <!-- archive bar -->
  <div class="relative border-b border-line py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-cmok/80">
      <span>▍ Machine 02 / Daily ritual · Closeness</span>
      <span class="hidden md:inline">one tap · daily · close circle · soft</span>
      <span>cmok.002 ▌</span>
    </div>
  </div>

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-32">

    <!-- header: cmok wordmark — LOWERCASE ITALIC SERIF (matches actual brand) -->
    <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end">
      <div class="col-span-12 md:col-span-8">
        <h2 class="font-display italic tracking-[-0.04em] leading-[0.85] text-cmok select-none text-[clamp(5rem,22vw,21rem)] lowercase">
          cmok<span class="text-ink not-italic">.</span>
        </h2>
        <p class="mt-2 font-mono text-[11px] tracking-[0.32em] uppercase text-cmok/70">
          pl. cmok = a peck, a kiss
        </p>
      </div>
      <div class="col-span-12 md:col-span-4 md:pb-4">
        <p class="font-display italic text-[clamp(1.5rem,2.8vw,2.2rem)] leading-[1.1] text-ink">
          {app.taglinePl}
        </p>
        <p class="mt-2 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint">
          en · {app.tagline}
        </p>
      </div>
    </div>

    <!-- intro line -->
    <p class="mt-10 sm:mt-14 max-w-2xl text-base sm:text-lg text-ink-dim leading-relaxed">
      <span>{app.intro[0]}</span>
      <span class="block text-ink">{app.intro[1]}</span>
    </p>

    <!-- ─── LOOP MACHINE ─── -->
    <div class="relative mt-20 sm:mt-32 grid grid-cols-12 gap-4 sm:gap-8 items-stretch">

      <!-- INPUT -->
      <div class="col-span-12 md:col-span-3 flex flex-col justify-between gap-8 md:border-r border-cmok/15 md:pr-6">
        <div class="space-y-2">
          <p class="callout text-flag mb-4">▍ Input</p>
          {app.input.map((line) => (
            <p class="font-display text-[clamp(1.6rem,3.5vw,2.4rem)] leading-[1.05] text-ink">
              <span class="text-flag mr-2 align-middle text-2xl">×</span>
              <span class="line-through decoration-flag/80 decoration-2 italic text-ink-dim">{line}</span>
            </p>
          ))}
        </div>

        <ul class="hidden md:block space-y-1">
          {app.bullets.map((b) => (
            <li class="text-ink-dim text-sm italic">· {b}</li>
          ))}
        </ul>
      </div>

      <div class="hidden md:flex md:col-span-1 items-center justify-center text-cmok/50" aria-hidden="true">
        <span class="text-3xl">→</span>
      </div>

      <!-- LOOP — close circle: ONE big breathing dot in center, small dots around -->
      <div class="col-span-12 md:col-span-5 relative flex items-center justify-center">
        <p class="absolute top-0 left-0 callout text-cmok">▍ Loop · once a day</p>
        <span aria-hidden="true" class="absolute top-0 right-0 stamp text-cmok/80">~ 2 sec</span>

        <svg
          viewBox="0 0 600 600"
          class="w-full h-auto text-cmok mt-10"
          role="img"
          aria-label={`Loop: ${app.loopSteps.join(" → ")} → repeat`}
        >
          <defs>
            <radialGradient id="cmok-glow-2" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="currentColor" stop-opacity="0.30" />
              <stop offset="60%" stop-color="currentColor" stop-opacity="0.06" />
              <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
            </radialGradient>
          </defs>

          <circle cx={cx} cy={cy} r="290" fill="url(#cmok-glow-2)" />

          <!-- subtle outer guide -->
          <circle cx={cx} cy={cy} r={labelRadius - 30} stroke="currentColor" stroke-opacity="0.12" fill="none" stroke-dasharray="2 6" />

          <!-- close-circle ring (subtle) -->
          <circle cx={cx} cy={cy} r={peopleRadius} stroke="currentColor" stroke-opacity="0.20" fill="none" />

          <!-- close-circle "people" dots — small, with their own soft echo -->
          <g>
            {people.map((p) => (
              <Fragment>
                <circle cx={p.x} cy={p.y} r="22" fill="currentColor" fill-opacity="0.18" style={`transform-origin: ${p.x}px ${p.y}px; animation: pulse-ring 4s ease-out ${p.delay}s infinite;`} />
                <circle cx={p.x} cy={p.y} r="9" fill="currentColor" />
              </Fragment>
            ))}
          </g>

          <!-- step labels -->
          <g font-family="JetBrains Mono, monospace" font-weight="600" font-size="14" letter-spacing="0.2em" fill="currentColor" fill-opacity="0.95" style="text-transform: uppercase;">
            {stepPositions.map((s) => (
              <Fragment>
                <text
                  x={s.x}
                  y={s.y}
                  text-anchor={s.angleDeg === -90 ? "middle" : (Math.cos((s.angleDeg * Math.PI) / 180) > 0 ? "start" : "end")}
                  dominant-baseline={s.angleDeg === -90 ? "auto" : "middle"}
                >{s.label}</text>
                <text
                  x={s.x}
                  y={s.y + 14}
                  text-anchor={s.angleDeg === -90 ? "middle" : (Math.cos((s.angleDeg * Math.PI) / 180) > 0 ? "start" : "end")}
                  font-size="9"
                  letter-spacing="0.18em"
                  fill-opacity="0.5"
                >{s.pl}</text>
              </Fragment>
            ))}
          </g>

          <!-- CENTER: the daily sign — big breathing circle -->
          <circle cx={cx} cy={cy} r="60" fill="none" stroke="currentColor" stroke-opacity="0.35" style="transform-origin: 300px 300px; animation: pulse-ring 3.6s ease-out infinite;" />
          <circle cx={cx} cy={cy} r="40" fill="currentColor" style="animation: drift 4s ease-in-out infinite;" />
          <text
            x={cx}
            y={cy + 6}
            text-anchor="middle"
            font-family="JetBrains Mono, monospace"
            font-weight="700"
            font-size="13"
            letter-spacing="0.22em"
            fill="var(--color-bg)"
            style="text-transform: uppercase;"
          >tap</text>
        </svg>

        <p class="absolute bottom-0 left-0 right-0 text-center callout text-cmok/70">
          {app.loopSteps.join(" → ")} → <span class="italic">repeat</span>
        </p>
      </div>

      <div class="hidden md:flex md:col-span-1 items-center justify-center text-cmok/50" aria-hidden="true">
        <span class="text-3xl">→</span>
      </div>

      <!-- OUTPUT -->
      <div class="col-span-12 md:col-span-2 flex flex-col justify-between gap-8 md:border-l border-cmok/15 md:pl-6">
        <div>
          <p class="callout text-cmok mb-4">▍ Output</p>
          <p class="font-display italic text-[clamp(1.8rem,3vw,2.4rem)] leading-[1.05] text-ink">
            {app.punchline}
          </p>
        </div>

        <a
          href={app.href!}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-2 callout text-ink hover:text-cmok transition-colors"
        >
          <span aria-hidden="true" class="block w-8 dim-line text-ink-faint group-hover:text-cmok transition-colors"></span>
          <span>App Store</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
        </a>
      </div>
    </div>
  </div>

  <!-- bottom strip -->
  <div class="relative border-t border-cmok/20 py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-cmok/50">
      <span>▍ End machine 02</span>
      <span class="hidden md:inline">— continue machine 03 —</span>
      <span>↓ ▌</span>
    </div>
  </div>
</section>
