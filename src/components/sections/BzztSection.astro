---
import { apps } from "../../data/apps.ts";
const app = apps.find((a) => a.id === "bzzt")!;
---

<section
  id="bzzt"
  class="relative isolate overflow-hidden border-t border-line scroll-mt-20 world-bzzt noise"
>
  <!-- archive bar -->
  <div class="relative border-b border-line py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-bzzt/80">
      <span>▍ Exhibit 01 · Machine 01 / Signal</span>
      <span class="hidden md:inline">freq · 2.4 GHz / range · nearby / scan · live</span>
      <span>BZZT.001 ▌</span>
    </div>
  </div>

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8 py-20 sm:py-32">

    <!-- huge wordmark -->
    <div class="relative">
      <h2 class="font-display tracking-[-0.04em] leading-[0.82] select-none">
        <span class="block text-[clamp(5rem,22vw,22rem)] text-bzzt">
          BZZT<span class="text-ink">.</span>
        </span>
      </h2>
      <!-- top-right tag -->
      <span aria-hidden="true" class="absolute top-2 right-0 callout text-bzzt/70 hidden sm:block">
        machine 01
      </span>
    </div>

    <!-- under-headline meta + tagline -->
    <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end mt-2 sm:mt-4">
      <p class="col-span-12 md:col-span-7 font-display italic text-[clamp(1.6rem,4vw,2.8rem)] leading-[1.05] text-ink">
        {app.tagline}
      </p>
      <div class="col-span-12 md:col-span-5 md:pl-6 md:border-l border-bzzt/30">
        <div class="space-y-1.5 text-ink">
          {app.intro.map((line) => <p class="text-base sm:text-lg leading-relaxed">{line}</p>)}
        </div>
      </div>
    </div>

    <!-- spec + radar composition -->
    <div class="mt-16 sm:mt-24 grid grid-cols-12 gap-4 sm:gap-8 items-center">

      <!-- left specs -->
      <dl class="col-span-12 md:col-span-3 space-y-5 font-mono text-[11px] tracking-[0.18em] uppercase text-ink-dim md:order-1">
        <div>
          <dt class="text-bzzt/80 mb-1">Freq</dt>
          <dd class="flex items-center gap-2">
            <span class="block w-10 dim-line text-bzzt/40"></span>
            <span class="text-ink">2.4 GHz</span>
          </dd>
        </div>
        <div>
          <dt class="text-bzzt/80 mb-1">Range</dt>
          <dd class="flex items-center gap-2">
            <span class="block w-10 dim-line text-bzzt/40"></span>
            <span class="text-ink">~ Nearby</span>
          </dd>
        </div>
        <div>
          <dt class="text-bzzt/80 mb-1">Mode</dt>
          <dd class="flex items-center gap-2">
            <span class="block w-10 dim-line text-bzzt/40"></span>
            <span class="text-ink">Mutual / live</span>
          </dd>
        </div>
        <div>
          <dt class="text-bzzt/80 mb-1">Decay</dt>
          <dd class="flex items-center gap-2">
            <span class="block w-10 dim-line text-bzzt/40"></span>
            <span class="text-ink">~ minutes</span>
          </dd>
        </div>
      </dl>

      <!-- radar (oversized, no box) -->
      <div class="col-span-12 md:col-span-6 md:order-2 relative">
        <svg
          viewBox="0 0 600 600"
          class="w-full h-auto text-bzzt"
          role="img"
          aria-label="Live proximity signal — concentric pulse rings, sweep, and pings"
        >
          <defs>
            <radialGradient id="bzzt-glow-2" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="currentColor" stop-opacity="0.18" />
              <stop offset="60%" stop-color="currentColor" stop-opacity="0.04" />
              <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
            </radialGradient>
            <linearGradient id="bzzt-sweep-2" x1="0%" y1="50%" x2="100%" y2="50%">
              <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
              <stop offset="100%" stop-color="currentColor" stop-opacity="0.45" />
            </linearGradient>
          </defs>

          <circle cx="300" cy="300" r="290" fill="url(#bzzt-glow-2)" />

          <!-- bearing labels -->
          <g font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="0.2em" fill="currentColor" fill-opacity="0.6">
            <text x="300" y="22" text-anchor="middle">N</text>
            <text x="582" y="304" text-anchor="end">E</text>
            <text x="300" y="592" text-anchor="middle">S</text>
            <text x="18" y="304">W</text>
          </g>

          <!-- baseline rings -->
          <g stroke="currentColor" fill="none" stroke-opacity="0.22">
            <circle cx="300" cy="300" r="80" />
            <circle cx="300" cy="300" r="160" />
            <circle cx="300" cy="300" r="240" />
          </g>

          <!-- crosshair -->
          <g stroke="currentColor" stroke-opacity="0.16" stroke-dasharray="2 6">
            <line x1="300" y1="40" x2="300" y2="560" />
            <line x1="40" y1="300" x2="560" y2="300" />
          </g>

          <!-- pulse rings -->
          <g stroke="currentColor" fill="none" style="transform-origin: 300px 300px;">
            <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out infinite;"></circle>
            <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 1.2s infinite;"></circle>
            <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 2.4s infinite;"></circle>
          </g>

          <!-- sweep -->
          <g style="transform-origin: 300px 300px; animation: spin 7s linear infinite;">
            <path d="M 300 300 L 580 300 A 280 280 0 0 0 440 60 Z" fill="url(#bzzt-sweep-2)" opacity="0.55" />
          </g>

          <!-- pings (with leader notes coming out) -->
          <g fill="currentColor">
            <circle cx="220" cy="200" r="4" style="animation: blink-soft 2.4s ease-in-out infinite;"></circle>
            <circle cx="410" cy="240" r="4" style="animation: blink-soft 3.1s ease-in-out 0.6s infinite;"></circle>
            <circle cx="360" cy="410" r="4" style="animation: blink-soft 2.8s ease-in-out 1.2s infinite;"></circle>
            <circle cx="180" cy="380" r="4" style="animation: blink-soft 3.4s ease-in-out 0.3s infinite;"></circle>
          </g>

          <!-- leader lines from pings to labels -->
          <g stroke="currentColor" stroke-opacity="0.45" fill="currentColor" fill-opacity="0.7" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.18em">
            <line x1="220" y1="200" x2="120" y2="120" stroke-dasharray="2 3" />
            <text x="20" y="116">BLIP · 0.4 km</text>
            <line x1="410" y1="240" x2="540" y2="160" stroke-dasharray="2 3" />
            <text x="450" y="154">MUTUAL · NEW</text>
          </g>

          <!-- center -->
          <circle cx="300" cy="300" r="6" fill="currentColor" />
          <circle cx="300" cy="300" r="14" fill="none" stroke="currentColor" stroke-opacity="0.7" />
        </svg>
      </div>

      <!-- right: bullets as "scan results" -->
      <div class="col-span-12 md:col-span-3 md:order-3">
        <p class="callout text-bzzt/80 mb-4">▍ Scan results</p>
        <ul class="space-y-2 font-display text-[clamp(1.4rem,2.4vw,1.9rem)] text-ink">
          {app.bullets.map((b, i) => (
            <li class="flex items-baseline gap-3">
              <span class="font-mono text-[10px] text-bzzt/70 w-6">0{i + 1}</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- bottom: punchline + CTA, asymmetric -->
    <div class="mt-20 sm:mt-28 grid grid-cols-12 gap-4 sm:gap-8 items-end">
      <p class="col-span-12 md:col-span-7 font-display italic text-[clamp(1.8rem,4.5vw,3.2rem)] leading-[1.05] text-ink">
        {app.punchline}
      </p>

      <div class="col-span-12 md:col-span-5 md:text-right flex md:justify-end">
        <a
          href={app.href!}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 callout text-ink hover:text-bzzt transition-colors"
        >
          <span aria-hidden="true" class="block w-12 dim-line text-ink-faint group-hover:text-bzzt transition-colors"></span>
          <span>Open BZZT</span>
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">↗</span>
        </a>
      </div>
    </div>
  </div>

  <!-- bottom border with archive footer -->
  <div class="relative border-t border-bzzt/20 py-2.5">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 flex items-center justify-between font-mono text-[10px] tracking-[0.28em] uppercase text-bzzt/50">
      <span>▍ End exhibit 01</span>
      <span class="hidden md:inline">— continue exhibit 02 —</span>
      <span>↓ ▌</span>
    </div>
  </div>
</section>
