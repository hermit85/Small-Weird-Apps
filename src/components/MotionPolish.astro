<script>
  const root = document.documentElement;
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  root.classList.add("js");

  const revealSelectors = [
    ".label-mono",
    ".motion-tappable",
    "[data-motion-visual] > *",
  ];

  const revealTargets = Array.from(document.querySelectorAll(revealSelectors.join(",")));
  revealTargets.forEach((target, index) => {
    if (!(target instanceof HTMLElement)) return;
    target.dataset.reveal = target.dataset.reveal || "";
    target.style.setProperty("--reveal-index", String(Math.min(index % 6, 5)));
  });

  const scrollToHash = (hash, shouldUpdateHistory = false) => {
    if (!hash || hash === "#") return;
    const target = document.getElementById(decodeURIComponent(hash.slice(1)));
    if (!target) return;

    target.scrollIntoView({
      behavior: prefersReducedMotion.matches ? "auto" : "smooth",
      block: "start",
    });

    if (shouldUpdateHistory) {
      history.pushState(null, "", hash);
    }
  };

  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", (event) => {
      if (!(anchor instanceof HTMLAnchorElement)) return;
      if (!anchor.hash) return;

      event.preventDefault();
      scrollToHash(anchor.hash, true);
    });
  });

  if (window.location.hash) {
    window.requestAnimationFrame(() => scrollToHash(window.location.hash));
  }

  if (!prefersReducedMotion.matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      {
        rootMargin: "0px 0px -12% 0px",
        threshold: 0.12,
      },
    );

    revealTargets.forEach((target) => observer.observe(target));

    const parallaxTargets = Array.from(document.querySelectorAll("[data-motion-visual]"));
    let ticking = false;

    const updateScrollState = () => {
      const maxScroll = Math.max(document.body.scrollHeight - window.innerHeight, 1);
      root.style.setProperty("--scroll-progress", String(window.scrollY / maxScroll));

      parallaxTargets.forEach((target) => {
        if (!(target instanceof HTMLElement)) return;
        const rect = target.getBoundingClientRect();
        const viewportCenter = window.innerHeight / 2;
        const distance = rect.top + rect.height / 2 - viewportCenter;
        const drift = Math.max(Math.min(distance / window.innerHeight, 1), -1) * -18;
        target.style.setProperty("--visual-drift", `${drift.toFixed(2)}px`);
      });

      ticking = false;
    };

    const requestScrollUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateScrollState);
    };

    updateScrollState();
    window.addEventListener("scroll", requestScrollUpdate, { passive: true });
    window.addEventListener("resize", requestScrollUpdate, { passive: true });

    /* ── timer ticks ──────────────────────────────────────────
       Two timers on the page (BZZT 30:00 countdown, NWD 01:42.07
       count-up). Each one ticks briefly when it enters the viewport
       so the readout reads as a live, recently-active timer rather
       than a static label. Animation runs once per timer per session
       and then settles. */
    const pad = (n, w = 2) => String(n).padStart(w, "0");

    const tickCountdown = (el) => {
      const minEl = el.querySelector("[data-min]");
      const secEl = el.querySelector("[data-sec]");
      if (!minEl || !secEl) return;
      let total = parseInt(el.dataset.timerStart || "1800", 10);
      const ticks = 6;       // 6 visible ticks
      const interval = 700;  // 0.7s per tick
      const apply = () => {
        minEl.textContent = pad(Math.floor(total / 60));
        secEl.textContent = pad(total % 60);
      };
      apply();
      let n = 0;
      const id = window.setInterval(() => {
        n += 1;
        total = Math.max(0, total - 1);
        apply();
        if (n >= ticks) window.clearInterval(id);
      }, interval);
    };

    const tickCountup = (el) => {
      const minEl = el.querySelector("[data-min]");
      const secEl = el.querySelector("[data-sec]");
      const csEl  = el.querySelector("[data-cs]");
      if (!minEl || !secEl || !csEl) return;
      let total = parseInt(el.dataset.timerStart || "0", 10); // centiseconds
      const ticks = 60;     // 60 ticks of 1cs at 28ms each ≈ 1.7s
      const interval = 28;
      const apply = () => {
        const mm = Math.floor(total / 6000);
        const ss = Math.floor((total % 6000) / 100);
        const cc = total % 100;
        minEl.textContent = pad(mm);
        secEl.textContent = pad(ss);
        csEl.textContent  = pad(cc);
      };
      apply();
      let n = 0;
      const id = window.setInterval(() => {
        n += 1;
        total += 1;
        apply();
        if (n >= ticks) window.clearInterval(id);
      }, interval);
    };

    const timerObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target;
          timerObserver.unobserve(el);
          const mode = el.dataset.timer;
          if (mode === "countdown") tickCountdown(el);
          else if (mode === "countup") tickCountup(el);
        });
      },
      { rootMargin: "0px 0px -8% 0px", threshold: 0.4 },
    );

    document.querySelectorAll("[data-timer]").forEach((el) => timerObserver.observe(el));
  } else {
    revealTargets.forEach((target) => target.classList.add("is-visible"));
  }
</script>
