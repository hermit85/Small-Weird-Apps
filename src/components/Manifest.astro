<section class="relative py-24 sm:py-32 border-t border-line-soft">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint mb-12 sm:mb-16">
      ▍ Manifest
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-12 gap-8 sm:gap-12">
      <p class="sm:col-span-7 sm:col-start-1 font-display text-[clamp(2rem,5vw,3.5rem)] leading-[1.05] text-ink">
        These are small apps.
      </p>

      <ul class="sm:col-span-7 sm:col-start-3 space-y-1 font-display text-[clamp(1.6rem,3.5vw,2.4rem)] leading-snug text-ink-dim">
        <li class="flex items-baseline gap-3"><span aria-hidden="true" class="text-ink-faint text-base">×</span><span class="line-through decoration-ink-faint/40">Not platforms.</span></li>
        <li class="flex items-baseline gap-3"><span aria-hidden="true" class="text-ink-faint text-base">×</span><span class="line-through decoration-ink-faint/40">Not feeds.</span></li>
        <li class="flex items-baseline gap-3"><span aria-hidden="true" class="text-ink-faint text-base">×</span><span class="line-through decoration-ink-faint/40">Not productivity empires.</span></li>
      </ul>

      <p class="sm:col-span-9 sm:col-start-2 mt-2 font-display text-[clamp(1.8rem,4vw,2.8rem)] leading-[1.1] text-ink">
        Just little loops for real moments:
      </p>

      <ul class="sm:col-span-9 sm:col-start-2 grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-8">
        <li class="rounded-2xl border border-line p-5 sm:p-6 bg-bg-soft/60">
          <span class="block font-mono text-[10px] tracking-[0.22em] uppercase text-bzzt mb-3">Loop 01</span>
          <span class="font-display text-2xl sm:text-3xl text-ink">a signal,</span>
        </li>
        <li class="rounded-2xl border border-line p-5 sm:p-6 bg-bg-soft/60">
          <span class="block font-mono text-[10px] tracking-[0.22em] uppercase text-cmok mb-3">Loop 02</span>
          <span class="font-display text-2xl sm:text-3xl text-ink">a check-in,</span>
        </li>
        <li class="rounded-2xl border border-line p-5 sm:p-6 bg-bg-soft/60">
          <span class="block font-mono text-[10px] tracking-[0.22em] uppercase text-nwd mb-3">Loop 03</span>
          <span class="font-display text-2xl sm:text-3xl text-ink">a race.</span>
        </li>
      </ul>

      <p class="sm:col-span-12 mt-8 font-display italic text-[clamp(1.6rem,4vw,2.6rem)] leading-snug text-ink">
        Useful. Strange. Nicely made.
      </p>
    </div>
  </div>
</section>
