---
---

<section class="relative py-24 sm:py-40 border-t border-line overflow-hidden">

  <!-- subtle diagonal wash -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.04]" aria-hidden="true"
    style="background-image: repeating-linear-gradient(-45deg, transparent 0 22px, rgba(243,238,226,0.5) 22px 23px);"></div>

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8">

    <!-- header -->
    <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end mb-14 sm:mb-20">
      <div class="col-span-12 md:col-span-3 label text-ink-faint">
        ▍ Section B.04
      </div>
      <div class="col-span-12 md:col-span-6">
        <p class="callout text-ink-faint">▍ Manifesto / publisher's note</p>
      </div>
      <div class="col-span-12 md:col-span-3 md:text-right">
        <span class="stamp text-ink-dim">draft · v.01</span>
      </div>
    </div>

    <!-- body manifesto, two-column asymmetric -->
    <div class="grid grid-cols-12 gap-4 sm:gap-12">

      <!-- left: declarations -->
      <div class="col-span-12 md:col-span-7 md:col-start-2">

        <h2 class="font-display text-[clamp(3.5rem,11vw,9rem)] leading-[0.92] tracking-tight text-ink">
          These are
          <span class="block italic text-ink-dim">small apps.</span>
        </h2>

        <!-- rejected categories — feel like crossed-out items in a list -->
        <ul class="mt-12 sm:mt-16 space-y-4 font-display text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1.1]">
          <li class="flex items-baseline gap-4 text-ink-dim">
            <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
            <span class="line-through decoration-flag/70 decoration-2">Not platforms.</span>
          </li>
          <li class="flex items-baseline gap-4 text-ink-dim">
            <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
            <span class="line-through decoration-flag/70 decoration-2">Not feeds.</span>
          </li>
          <li class="flex items-baseline gap-4 text-ink-dim">
            <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-6">×</span>
            <span class="line-through decoration-flag/70 decoration-2">Not productivity empires.</span>
          </li>
        </ul>

        <!-- counter -->
        <p class="mt-16 sm:mt-20 font-display text-[clamp(2rem,5.5vw,4rem)] leading-[1] text-ink">
          Just little loops
          <span class="block italic text-ink-dim">for real moments:</span>
        </p>

        <!-- three loops, set as a key/legend -->
        <ul class="mt-10 space-y-3 font-display text-[clamp(1.6rem,3vw,2.2rem)]">
          <li class="flex items-baseline gap-4 text-ink">
            <span class="font-mono text-[10px] tracking-[0.22em] text-bzzt w-6">01</span>
            <span aria-hidden="true" class="block w-12 sm:w-20 dim-line text-bzzt/60"></span>
            <span class="italic">a signal<span class="text-ink-faint">,</span></span>
          </li>
          <li class="flex items-baseline gap-4 text-ink">
            <span class="font-mono text-[10px] tracking-[0.22em] text-cmok w-6">02</span>
            <span aria-hidden="true" class="block w-12 sm:w-20 dim-line text-cmok/60"></span>
            <span class="italic">a check-in<span class="text-ink-faint">,</span></span>
          </li>
          <li class="flex items-baseline gap-4 text-ink">
            <span class="font-mono text-[10px] tracking-[0.22em] text-nwd w-6">03</span>
            <span aria-hidden="true" class="block w-12 sm:w-20 dim-line text-nwd/60"></span>
            <span class="italic">a race<span class="text-ink-faint">.</span></span>
          </li>
        </ul>
      </div>

      <!-- right: marginalia / stamp -->
      <aside class="hidden md:flex md:col-span-3 md:col-start-10 flex-col items-end gap-6 self-start mt-32">
        <span class="sticker text-flag">draft</span>
        <span class="callout text-ink-faint italic font-mono">
          ↑ rejected loops
        </span>
        <span class="block w-px h-32 bg-line"></span>
        <span class="callout text-ink-faint italic font-mono">
          ↓ accepted loops
        </span>
      </aside>
    </div>

    <!-- closing stamp — rotated, at bottom right -->
    <div class="relative mt-24 sm:mt-32 flex justify-center md:justify-end">
      <div class="inline-flex items-center gap-4 px-7 py-5 border border-ink/40 text-ink rounded-full">
        <span class="font-display italic text-[clamp(1.6rem,3vw,2.2rem)]">Useful.</span>
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-bzzt shadow-[0_0_10px_var(--color-bzzt)]"></span>
        <span class="font-display italic text-[clamp(1.6rem,3vw,2.2rem)]">Strange.</span>
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-cmok shadow-[0_0_10px_var(--color-cmok)]"></span>
        <span class="font-display italic text-[clamp(1.6rem,3vw,2.2rem)]">Nicely made.</span>
      </div>
    </div>
  </div>
</section>
