---
---

<section class="relative border-t border-line py-24 sm:py-40">
  <div class="mx-auto max-w-3xl px-5 sm:px-8 text-center">

    <p class="label-mono mb-12">▍ Manifesto</p>

    <h2 class="font-display text-[clamp(2.4rem,7vw,5rem)] leading-[1] text-ink">
      These are
      <span class="italic text-ink-dim">small apps.</span>
    </h2>

    <ul class="mt-10 space-y-2 font-display text-[clamp(1.6rem,3.6vw,2.4rem)] leading-tight text-ink-dim">
      <li class="flex items-baseline gap-3 justify-center">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-5">×</span>
        <span class="line-through decoration-flag/65 decoration-2">Not platforms.</span>
      </li>
      <li class="flex items-baseline gap-3 justify-center">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-5">×</span>
        <span class="line-through decoration-flag/65 decoration-2">Not feeds.</span>
      </li>
      <li class="flex items-baseline gap-3 justify-center">
        <span aria-hidden="true" class="text-flag font-mono text-base shrink-0 w-5">×</span>
        <span class="line-through decoration-flag/65 decoration-2">Not productivity empires.</span>
      </li>
    </ul>

    <p class="mt-12 font-display text-[clamp(1.8rem,4vw,2.8rem)] leading-tight text-ink">
      Just little loops for real moments:
    </p>

    <ul class="mt-6 space-y-1 font-display text-[clamp(1.4rem,2.8vw,2rem)]">
      <li class="text-ink"><span class="font-mono text-[10px] tracking-[0.22em] text-bzzt mr-3">01</span><span class="italic">a signal,</span></li>
      <li class="text-ink"><span class="font-mono text-[10px] tracking-[0.22em] text-cmok mr-3">02</span><span class="italic">a check-in,</span></li>
      <li class="text-ink"><span class="font-mono text-[10px] tracking-[0.22em] text-nwd mr-3">03</span><span class="italic">a race.</span></li>
    </ul>

    <div class="mt-14 inline-flex items-center gap-3 sm:gap-4 px-5 py-3.5 border border-ink/40 text-ink rounded-full">
      <span class="font-display italic text-[clamp(1.1rem,2.2vw,1.5rem)]">Useful.</span>
      <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-bzzt shadow-[0_0_10px_var(--color-bzzt)]"></span>
      <span class="font-display italic text-[clamp(1.1rem,2.2vw,1.5rem)]">Strange.</span>
      <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-cmok shadow-[0_0_10px_var(--color-cmok)]"></span>
      <span class="font-display italic text-[clamp(1.1rem,2.2vw,1.5rem)]">Nicely made.</span>
    </div>
  </div>
</section>
