---
// NWD — gravity racing.
// Motion contract:
//   ENTER:   trail line draws once (stroke-dashoffset).
//   ENTER:   live time + verified stamp fade in once.
//   STATIC:  gate, finish flag, leaderboard, mountain silhouette.
// (No ambient motion. NWD is "this is the result, frozen in time.")
const leaderboard = [
  { rank: 1, tag: "MTB.LD7", time: "01:38.42" },
  { rank: 2, tag: "GATE_K",  time: "01:39.07" },
  { rank: 3, tag: "DRT.PL",  time: "01:41.18" },
];
---

<div class="relative w-full max-w-md mx-auto" data-motion-visual>

  <!-- live HUD — STATIC. NWD is downhill MTB, not a gated event;
       the chip describes the state of the descent, not a 'gate'. -->
  <div class="absolute top-2 left-2 z-10 font-mono text-[10px] tracking-[0.28em] uppercase text-nwd flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-nwd shadow-[0_0_6px_var(--color-nwd)]"></span>
    descent · live
  </div>

  <!-- verified stamp — STATIC -->
  <span class="absolute top-2 right-2 z-10 inline-flex items-center gap-2 px-2.5 py-1 border border-nwd text-nwd font-mono text-[10px] tracking-[0.28em] uppercase -rotate-[6deg]">
    verified
  </span>

  <!-- mountain trail SVG -->
  <svg
    viewBox="0 0 480 280"
    class="w-full h-auto text-nwd"
    role="img"
    aria-label="NWD — drop-in point at the top, downhill trail line down the mountain, finish flag at the bottom"
  >
    <!-- mountain silhouette — STATIC, slightly stronger (0.05 → 0.07) -->
    <path d="M 0 280 L 60 60 L 200 200 L 280 240 L 380 170 L 480 60 L 480 280 Z" fill="currentColor" fill-opacity="0.07" />

    <!-- trail line — draws once on enter via stroke-dashoffset.
         The HTML 'descent · live' chip in the corner labels the run. -->
    <path
      class="trail-draw"
      d="M 60 60 L 200 200 L 280 240 L 380 170 L 480 60"
      stroke="currentColor" stroke-width="2.4" stroke-opacity="0.78" fill="none"
    />

    <!-- start node at the top of the trail (small dot, no label) -->
    <circle cx="60" cy="60" r="5" fill="currentColor" />

    <!-- finish flag — STATIC -->
    <g>
      <line x1="280" y1="240" x2="280" y2="220" stroke="currentColor" stroke-width="1.6" />
      <polygon points="280,220 300,225 280,232" fill="currentColor" />
      <text x="295" y="252" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.22em" fill="currentColor" style="text-transform: uppercase;">finish</text>
    </g>
  </svg>

  <!-- live time + leaderboard — one-shot reveal -->
  <div
    class="mt-3 flex items-end justify-between gap-4"
    style="animation: motion-soft-reveal 0.9s var(--motion-ease-apple) 0.75s both;"
  >
    <div>
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-nwd mb-0.5">▍ live time</p>
      <p
        data-timer="countup"
        data-timer-start="14207"
        class="font-mono font-bold text-nwd leading-none tracking-[-0.04em] tabular-nums"
        style="font-size: clamp(2.2rem, 6.4vw, 3.6rem);"
      ><span data-min>01</span>:<span data-sec>42</span><span class="text-nwd/70">.</span><span data-cs>07</span></p>
    </div>

    <ol class="font-mono text-[11px] divide-y divide-nwd/15 border-y border-nwd/35 min-w-[180px]">
      {leaderboard.map((row) => (
        <li class={`flex items-center justify-between gap-3 py-1 px-1.5 ${row.rank === 1 ? "text-nwd" : "text-ink-dim"}`}>
          <span class="flex items-center gap-2">
            <span class="tabular-nums w-4 text-right">{String(row.rank).padStart(2, "0")}</span>
            <span>{row.tag}</span>
          </span>
          <span class="tabular-nums">{row.time}</span>
        </li>
      ))}
    </ol>
  </div>
</div>
