---
// NWD — gravity racing.
// Motion contract:
//   ENTER:   trail line draws once (stroke-dashoffset).
//   ENTER:   live time + verified stamp fade in once.
//   STATIC:  gate, finish flag, leaderboard, mountain silhouette.
// (No ambient motion. NWD is "this is the result, frozen in time.")
const leaderboard = [
  { rank: 1, tag: "MTB.LD7", time: "01:38.42" },
  { rank: 2, tag: "GATE_K",  time: "01:39.07" },
  { rank: 3, tag: "DRT.PL",  time: "01:41.18" },
];
---

<div class="relative w-full max-w-md mx-auto" data-motion-visual>

  <!-- live HUD — STATIC. NWD is downhill MTB, not a gated event;
       the chip describes the state of the descent, not a 'gate'. -->
  <div class="absolute top-2 left-2 z-10 font-mono text-[10px] tracking-[0.28em] uppercase text-nwd flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-nwd shadow-[0_0_6px_var(--color-nwd)]"></span>
    descent · live
  </div>

  <!-- verified stamp — STATIC -->
  <span class="absolute top-2 right-2 z-10 inline-flex items-center gap-2 px-2.5 py-1 border border-nwd text-nwd font-mono text-[10px] tracking-[0.28em] uppercase -rotate-[6deg]">
    verified
  </span>

  <!-- mountain trail SVG -->
  <svg
    viewBox="0 0 480 280"
    class="w-full h-auto text-nwd"
    role="img"
    aria-label="NWD — drop-in point at the top, downhill trail line down the mountain, finish flag at the bottom"
  >
    <!-- mountain silhouette — fills everything below + left of the
         descent line so the trail reads as 'down the face of a mountain'
         instead of a zigzag chart. -->
    <path
      d="M 0 280 L 60 60 L 150 100 L 240 135 L 340 175 L 420 215 L 460 240 L 480 280 L 0 280 Z"
      fill="currentColor"
      fill-opacity="0.08"
    />

    <!-- descent line — proper monotonically descending profile from
         drop-in (top-left) to finish (bottom-right). Draws once on
         enter via stroke-dashoffset (CSS in global). -->
    <path
      class="trail-draw"
      pathLength="500"
      d="M 60 60 L 150 100 L 240 135 L 340 175 L 420 215 L 460 240"
      stroke="currentColor" stroke-width="2.6" stroke-opacity="0.85" fill="none"
      stroke-linecap="round" stroke-linejoin="round"
    />

    <!-- drop-in marker at the top of the trail -->
    <circle cx="60" cy="60" r="5" fill="currentColor" />
    <circle cx="60" cy="60" r="11" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1" />

    <!-- finish marker — checker flag PLANTED at the very end of the
         descent line. The trail terminates exactly at (460, 240); the
         pole is rooted there with a solid ground anchor, the flag waves
         out from the top. Bigger / taller than v1 so it reads as a
         confident "finish" marker rather than a timid afterthought. -->
    <g>
      <!-- pole base — solid anchor sitting ON the trail's last point.
           Filled disc + outer ring mirrors the drop-in marker at top so
           the two endpoints feel weighted equally. -->
      <circle cx="460" cy="240" r="4.5" fill="currentColor" />
      <circle cx="460" cy="240" r="9" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1" />
      <!-- pole rises from the endpoint -->
      <line x1="460" y1="240" x2="460" y2="194" stroke="currentColor" stroke-width="2" stroke-linecap="butt" />
      <!-- flag (3×2 checker on 18×16) — waves right from pole top.
           Stays within the 480-wide viewBox. -->
      <rect x="460" y="194" width="18" height="16" fill="currentColor" />
      <rect x="466" y="194" width="6"  height="8"  fill="var(--color-bg)" />
      <rect x="460" y="202" width="6"  height="8"  fill="var(--color-bg)" />
      <rect x="472" y="202" width="6"  height="8"  fill="var(--color-bg)" />
      <!-- 'finish' label sits below the ground anchor -->
      <text
        x="460" y="262"
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-size="9"
        letter-spacing="0.22em"
        fill="currentColor"
        style="text-transform: uppercase;"
      >finish</text>
    </g>
  </svg>

  <!-- live time + leaderboard — one-shot reveal -->
  <div
    class="mt-3 flex items-end justify-between gap-4"
    style="animation: motion-soft-reveal 0.9s var(--motion-ease-apple) 0.75s both;"
  >
    <div>
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-nwd mb-0.5">▍ live time</p>
      <p
        data-timer="countup"
        data-timer-start="10207"
        class="font-mono font-bold text-nwd leading-none tracking-[-0.04em] tabular-nums"
        style="font-size: clamp(2.2rem, 6.4vw, 3.6rem);"
      ><span data-min>01</span>:<span data-sec>42</span><span class="text-nwd/70">.</span><span data-cs>07</span></p>
    </div>

    <ol class="font-mono text-[11px] divide-y divide-nwd/15 border-y border-nwd/35 min-w-[180px]">
      {leaderboard.map((row) => (
        <li class={`flex items-center justify-between gap-3 py-1 px-1.5 ${row.rank === 1 ? "text-nwd" : "text-ink-dim"}`}>
          <span class="flex items-center gap-2">
            <span class="tabular-nums w-4 text-right">{String(row.rank).padStart(2, "0")}</span>
            <span>{row.tag}</span>
          </span>
          <span class="tabular-nums">{row.time}</span>
        </li>
      ))}
    </ol>
  </div>
</div>
