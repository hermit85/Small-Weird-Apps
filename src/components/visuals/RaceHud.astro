---
// NWD — race HUD / gate marker / leaderboard strip.
// Static composition with a gentle timer blink.
const leaderboard = [
  { rank: 1, tag: "MTB.LD7", time: "01:38.42", delta: null },
  { rank: 2, tag: "GATE_K", time: "01:39.07", delta: "+0.65" },
  { rank: 3, tag: "DRT.PL", time: "01:41.18", delta: "+2.76" },
  { rank: 4, tag: "—", time: "01:43.29", delta: "+4.87" },
];
---

<div class="relative aspect-square w-full max-w-md mx-auto" aria-hidden="true">
  <div class="absolute inset-0 rounded-3xl bg-gradient-to-tr from-nwd/8 via-transparent to-transparent"></div>

  <div class="relative h-full p-6 sm:p-8 flex flex-col gap-5">

    <!-- top: gate + status -->
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <svg width="22" height="22" viewBox="0 0 24 24" class="text-nwd"><path d="M3 4 L21 4 L21 8 L19 8 L19 20 L15 20 L15 8 L9 8 L9 20 L5 20 L5 8 L3 8 Z" fill="currentColor"/></svg>
        <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-nwd/80">Gate · armed</span>
      </div>
      <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Loop 03 · NWD</span>
    </div>

    <!-- timer -->
    <div class="flex items-end gap-3 leading-none">
      <span
        class="font-mono text-[clamp(2.5rem,9vw,4.5rem)] text-nwd tracking-tighter"
        style="animation: timer 1.2s ease-in-out infinite; font-feature-settings: 'tnum';"
      >01:42.07</span>
      <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint pb-2">live</span>
    </div>

    <!-- leaderboard -->
    <ul class="border border-line rounded-xl divide-y divide-line-soft overflow-hidden bg-bg-soft/60">
      {leaderboard.map((row) => (
        <li class="flex items-center justify-between px-4 py-2.5 font-mono text-[12px] text-ink">
          <span class="flex items-center gap-3">
            <span class={`tabular-nums w-4 text-right ${row.rank === 1 ? "text-nwd" : "text-ink-faint"}`}>{row.rank}</span>
            <span class={row.rank === 1 ? "text-ink" : "text-ink-dim"}>{row.tag}</span>
          </span>
          <span class="flex items-center gap-3">
            <span class="text-[10px] tracking-[0.2em] uppercase text-ink-faint">
              {row.delta ?? "leader"}
            </span>
            <span class={`tabular-nums ${row.rank === 1 ? "text-nwd" : "text-ink-dim"}`}>{row.time}</span>
          </span>
        </li>
      ))}
    </ul>

    <!-- bottom: gate strip -->
    <div class="mt-auto flex items-center gap-1 h-3">
      {Array.from({ length: 28 }).map((_, i) => (
        <span
          class={`flex-1 h-full ${i % 6 === 0 ? "bg-nwd" : "bg-line"} rounded-[1px]`}
        ></span>
      ))}
    </div>
  </div>
</div>
