---
// CMOK — daily reassurance loop. A calendar-like grid of small dots
// where today is a warmer, larger dot. Quiet, very subtle.
const cols = 14;
const rows = 7;
const total = cols * rows;
const todayIndex = Math.floor((rows / 2)) * cols + Math.floor(cols / 2) + 1;
const cells = Array.from({ length: total }, (_, i) => {
  const distance = Math.abs(i - todayIndex);
  const isToday = i === todayIndex;
  const isPast = i < todayIndex;
  return { i, isToday, isPast, distance };
});
---

<div class="relative aspect-square w-full max-w-md mx-auto" aria-hidden="true">
  <div class="absolute inset-0 rounded-3xl bg-gradient-to-br from-cmok/10 via-transparent to-transparent"></div>

  <div class="relative h-full p-8 flex flex-col justify-between">
    <div class="flex items-center justify-between font-mono text-[10px] tracking-[0.22em] uppercase">
      <span class="text-cmok/80">Daily · ok</span>
      <span class="text-ink-faint">14 weeks</span>
    </div>

    <div
      class="grid gap-[6px] mx-auto w-full"
      style={`grid-template-columns: repeat(${cols}, minmax(0, 1fr));`}
    >
      {cells.map((c) => (
        <div class="aspect-square flex items-center justify-center">
          {c.isToday ? (
            <span class="block w-full h-full rounded-full bg-cmok shadow-[0_0_18px_var(--color-cmok)]" style="animation: drift 4s ease-in-out infinite;"></span>
          ) : c.isPast ? (
            <span class={`block rounded-full bg-cmok/40`} style="width: 6px; height: 6px;"></span>
          ) : (
            <span class={`block rounded-full bg-ink-faint/30`} style="width: 4px; height: 4px;"></span>
          )}
        </div>
      ))}
    </div>

    <div class="flex items-end justify-between font-mono text-[10px] tracking-[0.22em] uppercase">
      <span class="text-ink-faint">Mon</span>
      <span class="text-cmok">Today · ✓</span>
      <span class="text-ink-faint">Sun</span>
    </div>
  </div>
</div>
