---
// CMOK — warm close circle, central tap, one OK SENT reply.
const cx = 240;
const cy = 240;

const peopleCount = 7;
const peopleRadius = 130;
const people = Array.from({ length: peopleCount }, (_, i) => {
  const angleDeg = -90 + (360 / peopleCount) * i;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    x: cx + peopleRadius * Math.cos(angleRad),
    y: cy + peopleRadius * Math.sin(angleRad),
    delay: (i * 0.4).toFixed(2),
  };
});

// pick second-from-top as the OK reply node
const okIndex = 1;
---

<div class="relative w-full max-w-md mx-auto">
  <svg
    viewBox="0 0 480 480"
    class="w-full h-auto text-cmok"
    role="img"
    aria-label="cmok — central daily sign, close circle of seven, one OK SENT reply"
  >
    <defs>
      <radialGradient id="cmok-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="currentColor" stop-opacity="0.26" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
    </defs>

    <circle cx={cx} cy={cy} r="230" fill="url(#cmok-glow)" />

    <!-- close-circle ring -->
    <circle cx={cx} cy={cy} r={peopleRadius} stroke="currentColor" stroke-opacity="0.22" fill="none" />

    <!-- subtle outer guide -->
    <circle cx={cx} cy={cy} r="195" stroke="currentColor" stroke-opacity="0.10" fill="none" stroke-dasharray="2 6" />

    <!-- subtle line: tap → OK reply -->
    <line
      x1={cx} y1={cy}
      x2={people[okIndex].x} y2={people[okIndex].y}
      stroke="currentColor" stroke-opacity="0.5"
      stroke-width="1.2" stroke-dasharray="3 4"
    />

    <!-- close-circle people -->
    <g>
      {people.map((p, i) => i !== okIndex && (
        <Fragment>
          <circle cx={p.x} cy={p.y} r="22" fill="currentColor" fill-opacity="0.16" style={`transform-origin: ${p.x}px ${p.y}px; animation: pulse-ring 4s ease-out ${p.delay}s infinite;`} />
          <circle cx={p.x} cy={p.y} r="9" fill="currentColor" fill-opacity="0.85" />
        </Fragment>
      ))}
    </g>

    <!-- OK reply node — special treatment -->
    <g>
      <circle cx={people[okIndex].x} cy={people[okIndex].y} r="36" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1" style={`transform-origin: ${people[okIndex].x}px ${people[okIndex].y}px; animation: pulse-ring 2.6s ease-out infinite;`} />
      <circle cx={people[okIndex].x} cy={people[okIndex].y} r="14" fill="currentColor" />
      <text
        x={people[okIndex].x} y={people[okIndex].y + 4}
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-weight="700"
        font-size="11"
        letter-spacing="0.16em"
        fill="var(--color-bg)"
      >ok ✓</text>
    </g>

    <!-- center: today's tap -->
    <circle cx={cx} cy={cy} r="60" fill="none" stroke="currentColor" stroke-opacity="0.35" style="transform-origin: 240px 240px; animation: pulse-ring 3.6s ease-out infinite;" />
    <circle cx={cx} cy={cy} r="42" fill="currentColor" style="animation: drift 4s ease-in-out infinite;" />
    <text
      x={cx} y={cy + 6}
      text-anchor="middle"
      font-family="JetBrains Mono, monospace"
      font-weight="700"
      font-size="13"
      letter-spacing="0.22em"
      fill="var(--color-bg)"
      style="text-transform: uppercase;"
    >tap</text>
  </svg>

  <!-- HUD -->
  <div class="absolute top-2 left-2 font-mono text-[9px] tracking-[0.28em] uppercase text-cmok/85 flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-cmok shadow-[0_0_6px_var(--color-cmok)]" style="animation: blink-soft 1.4s infinite;"></span>
    daily · 18:42
  </div>

  <div class="absolute top-2 right-2 inline-flex items-center gap-2 px-2.5 py-1 border border-cmok/85 text-cmok font-mono text-[9px] tracking-[0.28em] uppercase">
    ok sent
  </div>

  <div class="absolute bottom-3 right-3 font-mono text-[9px] tracking-[0.28em] uppercase text-cmok/60">
    1 reply
  </div>
</div>
