---
// CMOK — close circle around a daily tap.
// Motion contract:
//   AMBIENT: center TAP dot breathes (motion-breathe, 5s).
//   AMBIENT: center halo soft-pulses (motion-soft-pulse, 5s).
//   AMBIENT: ok-sent reply node soft-pulses subtly (motion-soft-pulse, 6s).
//   STATIC:  six other people-dots, dashed reply line, HUD chip, OK SENT stamp.
// Rationale:
//   CMOK is calm. Only the centre breathes; the close circle is a steady
//   ring of people. The OK reply is the only other live element.
const cx = 240;
const cy = 240;

const peopleCount = 7;
const peopleRadius = 130;
const people = Array.from({ length: peopleCount }, (_, i) => {
  const angleDeg = -90 + (360 / peopleCount) * i;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    x: cx + peopleRadius * Math.cos(angleRad),
    y: cy + peopleRadius * Math.sin(angleRad),
  };
});

// pick second-from-top as the OK reply node
const okIndex = 1;
---

<div class="relative w-full max-w-md mx-auto">
  <svg
    viewBox="0 0 480 480"
    class="w-full h-auto text-cmok"
    role="img"
    aria-label="cmok — central daily sign, close circle of seven, one OK SENT reply"
  >
    <defs>
      <radialGradient id="cmok-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="currentColor" stop-opacity="0.26" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
    </defs>

    <circle cx={cx} cy={cy} r="230" fill="url(#cmok-glow)" />

    <!-- close-circle ring — STATIC -->
    <circle cx={cx} cy={cy} r={peopleRadius} stroke="currentColor" stroke-opacity="0.22" fill="none" />

    <!-- subtle outer guide — STATIC -->
    <circle cx={cx} cy={cy} r="195" stroke="currentColor" stroke-opacity="0.10" fill="none" stroke-dasharray="2 6" />

    <!-- subtle line: tap → OK reply — STATIC -->
    <line
      x1={cx} y1={cy}
      x2={people[okIndex].x} y2={people[okIndex].y}
      stroke="currentColor" stroke-opacity="0.5"
      stroke-width="1.2" stroke-dasharray="3 4"
    />

    <!-- close-circle people — STATIC dots, no per-dot pulse -->
    <g>
      {people.map((p, i) => i !== okIndex && (
        <circle cx={p.x} cy={p.y} r="9" fill="currentColor" fill-opacity="0.78" />
      ))}
    </g>

    <!-- ok reply node — single subtle halo soft-pulse -->
    <g>
      <circle
        cx={people[okIndex].x} cy={people[okIndex].y}
        r="32"
        fill="none"
        stroke="currentColor" stroke-opacity="0.45" stroke-width="1"
        style={`transform-origin: ${people[okIndex].x}px ${people[okIndex].y}px; animation: motion-soft-pulse 6s var(--motion-ease-ambient) 0.5s infinite;`}
      />
      <circle cx={people[okIndex].x} cy={people[okIndex].y} r="14" fill="currentColor" />
      <text
        x={people[okIndex].x} y={people[okIndex].y + 4}
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-weight="700"
        font-size="11"
        letter-spacing="0.16em"
        fill="var(--color-bg)"
      >ok ✓</text>
    </g>

    <!-- center: TAP — soft halo + breathing dot -->
    <circle
      cx={cx} cy={cy} r="56"
      fill="none"
      stroke="currentColor" stroke-opacity="0.30"
      style="transform-origin: 240px 240px; animation: motion-soft-pulse 5s var(--motion-ease-ambient) infinite;"
    />
    <circle
      cx={cx} cy={cy} r="42"
      fill="currentColor"
      style="animation: motion-breathe 5s var(--motion-ease-ambient) infinite;"
    />
    <text
      x={cx} y={cy + 6}
      text-anchor="middle"
      font-family="JetBrains Mono, monospace"
      font-weight="700"
      font-size="13"
      letter-spacing="0.22em"
      fill="var(--color-bg)"
      style="text-transform: uppercase;"
    >tap</text>
  </svg>

  <!-- HUD — STATIC -->
  <div class="absolute top-2 left-2 font-mono text-[9px] tracking-[0.28em] uppercase text-cmok/85 flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-cmok shadow-[0_0_6px_var(--color-cmok)]"></span>
    daily · 18:42
  </div>

  <div class="absolute top-2 right-2 inline-flex items-center gap-2 px-2.5 py-1 border border-cmok/85 text-cmok font-mono text-[9px] tracking-[0.28em] uppercase">
    ok sent
  </div>

  <div class="absolute bottom-3 right-3 font-mono text-[9px] tracking-[0.28em] uppercase text-cmok/60">
    1 reply
  </div>
</div>
