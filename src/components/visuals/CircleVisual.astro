---
// CMOK — close circle around a daily tap.
// Motion contract:
//   AMBIENT: ONE slow soft-pulse on the centre TAP halo (5s).
//   ENTER:   OK reply + 'OK SENT' stamp fade in once on first paint.
//   STATIC:  TAP centre dot, six other people-dots, dashed reply line,
//            HUD chip.
const cx = 240;
const cy = 240;

const peopleCount = 7;
const peopleRadius = 130;
const people = Array.from({ length: peopleCount }, (_, i) => {
  const angleDeg = -90 + (360 / peopleCount) * i;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    x: cx + peopleRadius * Math.cos(angleRad),
    y: cy + peopleRadius * Math.sin(angleRad),
  };
});

const okIndex = 1;
---

<div class="relative w-full max-w-md mx-auto">
  <svg
    viewBox="0 0 480 480"
    class="w-full h-auto text-cmok"
    role="img"
    aria-label="cmok — central daily sign, close circle of seven, one OK SENT reply"
  >
    <defs>
      <radialGradient id="cmok-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%"  stop-color="currentColor" stop-opacity="0.32" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
    </defs>

    <circle cx={cx} cy={cy} r="230" fill="url(#cmok-glow)" />

    <!-- close-circle ring — STATIC, brighter (0.22 → 0.32) -->
    <circle cx={cx} cy={cy} r={peopleRadius} stroke="currentColor" stroke-opacity="0.32" fill="none" />

    <!-- subtle outer guide — STATIC -->
    <circle cx={cx} cy={cy} r="195" stroke="currentColor" stroke-opacity="0.12" fill="none" stroke-dasharray="2 6" />

    <!-- subtle line: tap → OK reply — STATIC -->
    <line
      x1={cx} y1={cy}
      x2={people[okIndex].x} y2={people[okIndex].y}
      stroke="currentColor" stroke-opacity="0.55"
      stroke-width="1.2" stroke-dasharray="3 4"
    />

    <!-- close-circle people — STATIC dots, brighter (0.78 → 0.88) -->
    <g>
      {people.map((p, i) => i !== okIndex && (
        <circle cx={p.x} cy={p.y} r="9" fill="currentColor" fill-opacity="0.88" />
      ))}
    </g>

    <!-- ok reply — one-shot reveal -->
    <g style={`transform-origin: ${people[okIndex].x}px ${people[okIndex].y}px; animation: motion-soft-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.55s both;`}>
      <circle cx={people[okIndex].x} cy={people[okIndex].y} r="32" fill="none" stroke="currentColor" stroke-opacity="0.55" stroke-width="1" />
      <circle cx={people[okIndex].x} cy={people[okIndex].y} r="14" fill="currentColor" />
      <text
        x={people[okIndex].x} y={people[okIndex].y + 4}
        text-anchor="middle"
        font-family="JetBrains Mono, monospace"
        font-weight="700"
        font-size="11"
        letter-spacing="0.16em"
        fill="var(--color-bg)"
      >ok ✓</text>
    </g>

    <!-- centre TAP — one ambient soft-pulse on the halo only -->
    <circle
      cx={cx} cy={cy} r="56"
      fill="none"
      stroke="currentColor" stroke-opacity="0.38"
      style="transform-origin: 240px 240px; animation: motion-soft-pulse 5s cubic-bezier(0.45, 0, 0.55, 1) infinite;"
    />
    <circle cx={cx} cy={cy} r="44" fill="currentColor" />
    <text
      x={cx} y={cy + 6}
      text-anchor="middle"
      font-family="JetBrains Mono, monospace"
      font-weight="700"
      font-size="14"
      letter-spacing="0.22em"
      fill="var(--color-bg)"
      style="text-transform: uppercase;"
    >tap</text>
  </svg>

  <!-- HUD — STATIC -->
  <div class="absolute top-2 left-2 font-mono text-[10px] tracking-[0.28em] uppercase text-cmok flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-cmok shadow-[0_0_6px_var(--color-cmok)]"></span>
    daily · 18:42
  </div>

  <!-- OK SENT stamp — one-shot reveal -->
  <div
    class="absolute top-2 right-2 inline-flex items-center gap-2 px-2.5 py-1 border border-cmok text-cmok font-mono text-[10px] tracking-[0.28em] uppercase"
    style="animation: motion-soft-reveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;"
  >
    ok sent
  </div>

  <div class="absolute bottom-3 right-3 font-mono text-[10px] tracking-[0.28em] uppercase text-cmok/65">
    1 reply
  </div>
</div>
