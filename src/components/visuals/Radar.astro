---
// BZZT — radar / proximity signal / spark.
// Pure SVG + CSS. Respects prefers-reduced-motion via global rule.
---

<div class="relative aspect-square w-full max-w-md mx-auto" aria-hidden="true">
  <svg
    viewBox="0 0 400 400"
    class="w-full h-full text-bzzt"
    role="img"
    aria-label="Live proximity signal"
  >
    <defs>
      <radialGradient id="bzzt-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.18" />
        <stop offset="60%" stop-color="currentColor" stop-opacity="0.04" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="bzzt-sweep" x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0.55" />
      </linearGradient>
    </defs>

    <circle cx="200" cy="200" r="190" fill="url(#bzzt-glow)" />

    <!-- baseline static rings -->
    <g stroke="currentColor" fill="none" stroke-opacity="0.18">
      <circle cx="200" cy="200" r="60" />
      <circle cx="200" cy="200" r="110" />
      <circle cx="200" cy="200" r="160" />
    </g>

    <!-- crosshair -->
    <g stroke="currentColor" stroke-opacity="0.12" stroke-dasharray="2 6">
      <line x1="200" y1="20" x2="200" y2="380" />
      <line x1="20" y1="200" x2="380" y2="200" />
    </g>

    <!-- pulse rings -->
    <g class="bzzt-pulse" stroke="currentColor" fill="none" style="transform-origin: 200px 200px;">
      <circle cx="200" cy="200" r="180" stroke-width="1" style="animation: pulse-ring 3.6s ease-out infinite;"></circle>
      <circle cx="200" cy="200" r="180" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 1.2s infinite;"></circle>
      <circle cx="200" cy="200" r="180" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 2.4s infinite;"></circle>
    </g>

    <!-- sweep -->
    <g style="transform-origin: 200px 200px; animation: spin 7s linear infinite;">
      <path d="M 200 200 L 380 200 A 180 180 0 0 0 280 60 Z" fill="url(#bzzt-sweep)" opacity="0.55" />
    </g>

    <!-- pings -->
    <g fill="currentColor">
      <circle cx="148" cy="142" r="3" style="animation: blink-soft 2.4s ease-in-out infinite;"></circle>
      <circle cx="278" cy="170" r="3" style="animation: blink-soft 3.1s ease-in-out 0.6s infinite;"></circle>
      <circle cx="240" cy="276" r="3" style="animation: blink-soft 2.8s ease-in-out 1.2s infinite;"></circle>
      <circle cx="118" cy="248" r="3" style="animation: blink-soft 3.4s ease-in-out 0.3s infinite;"></circle>
    </g>

    <!-- center -->
    <circle cx="200" cy="200" r="6" fill="currentColor" />
    <circle cx="200" cy="200" r="14" fill="none" stroke="currentColor" stroke-opacity="0.6" />
  </svg>

  <div class="absolute top-3 left-3 font-mono text-[10px] tracking-[0.22em] uppercase text-bzzt/80">
    Signal · live
  </div>
  <div class="absolute bottom-3 right-3 font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">
    +52.23° N
  </div>
</div>

<style>
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
