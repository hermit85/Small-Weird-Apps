---
import { site } from "../data/site.ts";
---

<section class="relative pt-20 sm:pt-32 pb-20 sm:pb-28">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex items-baseline gap-3 mb-12 sm:mb-20 font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint">
      <span aria-hidden="true">▍</span>
      <span>A tiny indie app label</span>
      <span class="hidden sm:inline">— Warsaw, 2026</span>
    </div>

    <h1 class="font-display text-[clamp(3rem,11vw,9.5rem)] leading-[0.92] tracking-tight">
      <span class="block text-ink">Real problems.</span>
      <span class="block text-ink-dim italic">Strange little loops.</span>
    </h1>

    <div class="mt-12 sm:mt-16 grid grid-cols-1 sm:grid-cols-12 gap-6 sm:gap-12">
      <ul class="sm:col-span-7 font-display text-[clamp(1.4rem,2.6vw,2.1rem)] leading-snug text-ink space-y-1.5">
        <li class="flex items-baseline gap-3">
          <span class="font-mono text-[10px] tracking-[0.2em] text-bzzt opacity-80">01</span>
          <span>Dating without endless swiping.</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="font-mono text-[10px] tracking-[0.2em] text-cmok opacity-80">02</span>
          <span>Safety without panic theatre.</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="font-mono text-[10px] tracking-[0.2em] text-nwd opacity-80">03</span>
          <span>Racing without waiting for an event.</span>
        </li>
      </ul>

      <div class="sm:col-span-5 flex flex-col justify-end gap-7">
        <p class="text-base sm:text-lg leading-relaxed text-ink-dim max-w-sm">
          {site.description}
        </p>
        <div class="flex flex-wrap items-center gap-3">
          <a
            href="#apps"
            class="group inline-flex items-center gap-2 px-5 py-3 rounded-full bg-ink text-bg font-mono text-[11px] tracking-[0.2em] uppercase hover:bg-bzzt transition-colors"
          >
            Explore the apps
            <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">↓</span>
          </a>
          <a
            href="#company"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-full border border-line text-ink-dim hover:text-ink hover:border-ink-dim font-mono text-[11px] tracking-[0.2em] uppercase transition-colors"
          >
            Company info
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
