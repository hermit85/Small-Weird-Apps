---
---

<section class="relative min-h-[100svh] flex flex-col">

  <!-- thin top status -->
  <div class="border-b border-line">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 py-3 flex items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]" style="animation: blink-soft 2s infinite;"></span>
        <span class="text-ink">Small Weird Apps</span>
      </span>
      <span class="text-right">Warsaw · 2026</span>
    </div>
  </div>

  <!-- main poster -->
  <div class="relative flex-1 flex flex-col justify-center w-full">
    <div class="relative mx-auto max-w-[1600px] px-5 sm:px-12 lg:px-16 w-full py-16 sm:py-24">

      <!-- wordmark -->
      <h1 class="font-display tracking-[-0.04em] leading-[0.82] select-none">
        <span class="reveal r-1 block text-[clamp(4.5rem,18vw,18rem)] text-ink">Small</span>
        <span class="reveal r-2 block text-[clamp(4.5rem,18vw,18rem)] italic text-bzzt -mt-[1.2vw] pl-[6vw] sm:pl-[12vw]">weird</span>
        <span class="reveal r-3 block text-[clamp(4.5rem,18vw,18rem)] text-ink -mt-[1.2vw]">Apps<span class="text-bzzt">.</span></span>
      </h1>

      <!-- manifesto + subcopy -->
      <div class="reveal r-4 mt-12 sm:mt-20 grid grid-cols-12 gap-6 sm:gap-12 items-end">
        <p class="col-span-12 md:col-span-7 font-display text-[clamp(2rem,5vw,4rem)] leading-[1] text-ink">
          Real problems.
          <span class="block italic text-ink-dim">Strange little loops.</span>
        </p>
        <p class="col-span-12 md:col-span-5 text-base sm:text-lg leading-relaxed text-ink-dim md:pl-8 md:border-l border-line">
          Three small mobile apps for three very normal problems
          that deserved <span class="italic text-ink">weirder answers</span>.
        </p>
      </div>

      <!-- scroll cue -->
      <div class="reveal r-4 mt-16 sm:mt-24 flex items-center gap-3 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
        <span aria-hidden="true" class="block w-12 h-px bg-line"></span>
        <a href="#problems" class="hover:text-ink transition-colors">three problems below</a>
        <span aria-hidden="true">↓</span>
      </div>
    </div>
  </div>
</section>
