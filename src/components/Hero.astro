---
const apps = [
  { id: "bzzt", n: "01", brand: "BZZT", brandClass: "font-mono font-bold uppercase tracking-tight",                      blurb: "meet people nearby",  accent: "bzzt" },
  { id: "cmok", n: "02", brand: "cmok", brandClass: "font-display italic lowercase tracking-tight",                      blurb: "send a daily sign",   accent: "cmok" },
  { id: "nwd",  n: "03", brand: "NWD",  brandClass: "font-display tracking-tight",                                       blurb: "race real trails",    accent: "nwd"  },
];
---

<section class="relative min-h-[100svh] flex flex-col">

  <!-- thin top status — carries the publisher attribution above the fold -->
  <div class="border-b border-line">
    <div class="mx-auto max-w-[1600px] px-5 sm:px-8 py-3 flex items-center justify-between gap-4 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
      <span class="flex items-center gap-2">
        <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_8px_var(--color-bzzt)]"></span>
        <span class="text-ink">Small Weird Apps</span>
      </span>
      <span class="hidden md:inline">a product label by <span class="text-ink-dim">Cybird Consulting</span></span>
      <span class="text-right">Warsaw · 2026</span>
    </div>
  </div>

  <!-- main poster -->
  <div class="relative flex-1 flex flex-col justify-center w-full">
    <div class="relative mx-auto max-w-[1600px] px-5 sm:px-12 lg:px-16 w-full py-16 sm:py-24">

      <!-- wordmark — static -->
      <h1 class="font-display tracking-[-0.04em] leading-[0.82] select-none">
        <span class="block text-[clamp(4.5rem,18vw,18rem)] text-ink">Small</span>
        <span class="block text-[clamp(4.5rem,18vw,18rem)] italic text-bzzt -mt-[1.2vw] pl-[6vw] sm:pl-[12vw]">weird</span>
        <span class="block text-[clamp(4.5rem,18vw,18rem)] text-ink -mt-[1.2vw]">Apps<span class="text-bzzt">.</span></span>
      </h1>

      <!-- manifesto + app index -->
      <div class="mt-12 sm:mt-20 grid grid-cols-12 gap-8 sm:gap-12 items-end">
        <p class="col-span-12 md:col-span-6 font-display text-[clamp(2.2rem,5.5vw,4.5rem)] leading-[1] text-ink">
          Real problems.
          <span class="block italic text-ink-dim">Strange little loops.</span>
        </p>

        <!-- app index — bumped contrast & size; this is content, not ornament -->
        <div class="col-span-12 md:col-span-6 md:pl-8 md:border-l border-line">
          <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-dim mb-5">
            Three small mobile apps
          </p>
          <ul class="space-y-3">
            {apps.map((a) => (
              <li>
                <a
                  href={`#${a.id}`}
                  class={`group inline-flex items-baseline gap-3 text-ink hover:text-${a.accent} transition-colors`}
                >
                  <span class={`font-mono text-[11px] tracking-[0.22em] text-${a.accent} w-6`}>[{a.n}]</span>
                  <span class={`${a.brandClass} text-[clamp(1.6rem,2.6vw,1.95rem)] text-${a.accent}`}>{a.brand}</span>
                  <span class="text-ink-faint" aria-hidden="true">·</span>
                  <span class="text-lg sm:text-xl text-ink/90 group-hover:text-ink transition-colors">{a.blurb}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- scroll cue -->
      <div class="mt-16 sm:mt-24 flex items-center gap-3 font-mono text-[10px] tracking-[0.28em] uppercase text-ink-faint">
        <span aria-hidden="true" class="block w-12 h-px bg-line"></span>
        <a href="#problems" class="hover:text-ink transition-colors">three problems below</a>
        <span aria-hidden="true">↓</span>
      </div>
    </div>
  </div>
</section>
