---
import type { AppData } from "../data/apps.ts";

interface Props {
  app: AppData;
  /** kicker line, e.g. "01 / Dating" */
  kicker: string;
  /** big headline (the WEIRD ANSWER promise) */
  headline: string;
  /** one-sentence description of what the app actually does */
  story: string;
  /** short steps describing the loop in human terms */
  steps: string[];
  /** punchline */
  punch: string;
  /** flip the visual to the right (default) or left */
  reverse?: boolean;
  /** override CTA text */
  cta?: string;
}

const {
  app,
  kicker,
  headline,
  story,
  steps,
  punch,
  reverse = false,
  cta = `Open ${app.name}`,
} = Astro.props;

const accent = app.accent;
const brandClass =
  app.id === "bzzt" ? "font-mono font-bold uppercase tracking-[-0.02em]" :
  app.id === "cmok" ? "font-display italic lowercase tracking-[-0.02em]" :
                      "font-display tracking-[-0.04em]";
---

<section
  id={app.id}
  class="relative border-t border-line py-20 sm:py-32 scroll-mt-12 overflow-hidden"
>
  <div class="mx-auto max-w-[1600px] px-5 sm:px-12 lg:px-16">
    <div class={`grid grid-cols-12 gap-8 sm:gap-12 lg:gap-16 items-start ${reverse ? "lg:[&>:first-child]:order-2" : ""}`}>

      <!-- COPY column -->
      <div class="col-span-12 lg:col-span-7 order-2 lg:order-1">
        <p class={`font-mono text-[11px] tracking-[0.28em] uppercase text-${accent}`}>{kicker}</p>

        <h2 class="mt-3 font-display text-[clamp(2.6rem,7.5vw,5.5rem)] leading-[0.96] text-ink">
          {headline}
        </h2>

        <p class="mt-8 sm:mt-10 max-w-xl text-lg sm:text-xl leading-relaxed text-ink">
          {story}
        </p>

        <ul class="mt-8 space-y-1.5 font-display text-[clamp(1.4rem,2.6vw,2rem)] leading-tight text-ink">
          {steps.map((s, i) => (
            <li class="flex items-baseline gap-3">
              <span class={`font-mono text-[10px] tracking-[0.22em] text-${accent}/70 w-6`}>0{i + 1}</span>
              <span>{s}</span>
            </li>
          ))}
        </ul>

        <p class={`mt-10 font-display italic text-[clamp(1.6rem,3.6vw,2.6rem)] leading-snug text-ink`}>
          {punch}
        </p>

        <div class="mt-10 flex flex-wrap items-center gap-5">
          {app.href ? (
            <a
              href={app.href}
              target="_blank"
              rel="noopener"
              class={`motion-tappable group inline-flex items-center gap-3 px-6 py-4 border border-${accent}/60 hover:bg-${accent}/15 hover:border-${accent} font-mono text-[12px] tracking-[0.22em] uppercase`}
            >
              <span aria-hidden="true" class={`block w-1.5 h-1.5 rounded-full bg-${accent} shadow-[0_0_8px_currentColor] text-${accent}`}></span>
              <span class="text-ink">{cta}</span>
              <span aria-hidden="true" class="text-ink transition-transform group-hover:translate-x-1">↗</span>
            </a>
          ) : (
            <span class="inline-flex items-center gap-2 px-6 py-4 border border-line text-ink-faint font-mono text-[12px] tracking-[0.22em] uppercase">
              <span>Soon</span>
            </span>
          )}

          <span class={`${brandClass} text-2xl sm:text-3xl text-${accent}`}>
            {app.name}<span class="text-ink">.</span>
          </span>
        </div>
      </div>

      <!-- VISUAL column -->
      <div class="col-span-12 lg:col-span-5 order-1 lg:order-2 flex items-center justify-center">
        <slot name="visual" />
      </div>
    </div>
  </div>
</section>
