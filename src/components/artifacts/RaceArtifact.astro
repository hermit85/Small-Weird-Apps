---
import { apps } from "../../data/apps.ts";
const app = apps.find((a) => a.id === "nwd")!;

const stations = app.loopSteps.map((label, i) => {
  const xs = [60, 195, 300, 405, 540];
  const ys = [60, 210, 270, 210, 60];
  return { label, x: xs[i], y: ys[i] };
});
---

<div class="relative">
  <svg
    viewBox="0 0 600 320"
    class="w-full h-auto text-nwd"
    role="img"
    aria-label="NWD gravity loop — five stations on a downhill profile with a return arc"
  >
    <path d="M 0 320 L 60 60 L 195 210 L 300 270 L 405 210 L 540 60 L 600 320 Z" fill="currentColor" fill-opacity="0.05" />
    <path d="M 60 60 L 195 210 L 300 270 L 405 210 L 540 60" stroke="currentColor" stroke-width="2" stroke-opacity="0.55" fill="none" />
    <path d="M 540 60 Q 300 -20, 60 60" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.55" stroke-dasharray="3 5" fill="none" />
    <polygon points="60,60 70,55 70,65" fill="currentColor" fill-opacity="0.7" />

    <text x="300" y="14" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="0.22em" fill="currentColor" fill-opacity="0.55" style="text-transform: uppercase;">wróć na górę</text>

    {stations.map((s, i) => (
      <Fragment>
        <circle cx={s.x} cy={s.y} r="6" fill="currentColor" style={`animation: blink-soft ${2 + i * 0.3}s ease-in-out ${i * 0.2}s infinite;`} />
        <circle cx={s.x} cy={s.y} r="14" fill="none" stroke="currentColor" stroke-opacity="0.4" />
        <text x={s.x} y={s.y > 200 ? s.y + 32 : s.y - 22} text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="600" font-size="13" letter-spacing="0.2em" fill="currentColor" fill-opacity="0.95" style="text-transform: uppercase;">{s.label}</text>
      </Fragment>
    ))}
  </svg>

  <!-- secondary HUD: timer + leaderboard, compact -->
  <div class="mt-6 grid grid-cols-12 gap-4 items-end">
    <div class="col-span-7">
      <p class="font-mono text-[10px] tracking-[0.28em] uppercase text-nwd/70 mb-1">▍ live time</p>
      <p
        class="font-mono font-medium text-nwd leading-none tracking-[-0.04em] tabular-nums"
        style="font-size: clamp(2rem, 6vw, 3.6rem); animation: timer 1.4s ease-in-out infinite;"
      >01:42<span class="text-nwd/70">.</span>07</p>
    </div>
    <ol class="col-span-5 font-mono text-[10px] text-ink divide-y divide-nwd/15 border-y border-nwd/30">
      <li class="flex items-center justify-between py-1 text-nwd"><span><span class="tabular-nums w-4 inline-block text-right mr-1.5">01</span>MTB.LD7</span><span class="tabular-nums">01:38.42</span></li>
      <li class="flex items-center justify-between py-1 text-ink-dim"><span><span class="tabular-nums w-4 inline-block text-right mr-1.5">02</span>GATE_K</span><span class="tabular-nums">01:39.07</span></li>
      <li class="flex items-center justify-between py-1 text-ink-dim"><span><span class="tabular-nums w-4 inline-block text-right mr-1.5">03</span>DRT.PL</span><span class="tabular-nums">01:41.18</span></li>
    </ol>
  </div>
</div>
