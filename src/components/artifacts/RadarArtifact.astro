---
// BZZT — live proximity scene.
// You at center, 3 anonymous nearby pings, 1 mutual spark with a 30:00 countdown.
// No abstract loop-step labels — those are in the inspector.
---

<div class="relative">
  <svg
    viewBox="0 0 600 600"
    class="w-full h-auto text-bzzt"
    role="img"
    aria-label="BZZT live radar — you at center, 3 anonymous pings, 1 mutual spark with 30-minute countdown"
  >
    <defs>
      <radialGradient id="bzzt-glow-c" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.20" />
        <stop offset="60%" stop-color="currentColor" stop-opacity="0.04" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
      <linearGradient id="bzzt-sweep-c" x1="0%" y1="50%" x2="100%" y2="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0.55" />
      </linearGradient>
    </defs>

    <circle cx="300" cy="300" r="290" fill="url(#bzzt-glow-c)" />

    <!-- baseline rings -->
    <g stroke="currentColor" fill="none" stroke-opacity="0.16">
      <circle cx="300" cy="300" r="100" />
      <circle cx="300" cy="300" r="180" />
      <circle cx="300" cy="300" r="260" />
    </g>

    <!-- compass marks (tiny, no labels) -->
    <g stroke="currentColor" stroke-opacity="0.20">
      <line x1="300" y1="36" x2="300" y2="50"  />
      <line x1="300" y1="550" x2="300" y2="564" />
      <line x1="36"  y1="300" x2="50"  y2="300" />
      <line x1="550" y1="300" x2="564" y2="300" />
    </g>

    <!-- crosshair (subtle) -->
    <g stroke="currentColor" stroke-opacity="0.10" stroke-dasharray="2 8">
      <line x1="300" y1="60" x2="300" y2="540" />
      <line x1="60" y1="300" x2="540" y2="300" />
    </g>

    <!-- pulse rings -->
    <g stroke="currentColor" fill="none" style="transform-origin: 300px 300px;">
      <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out infinite;"></circle>
      <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 1.2s infinite;"></circle>
      <circle cx="300" cy="300" r="270" stroke-width="1" style="animation: pulse-ring 3.6s ease-out 2.4s infinite;"></circle>
    </g>

    <!-- sweep -->
    <g style="transform-origin: 300px 300px; animation: spin 7s linear infinite;">
      <path d="M 300 300 L 580 300 A 280 280 0 0 0 440 60 Z" fill="url(#bzzt-sweep-c)" opacity="0.6" />
    </g>

    <!-- 3 anonymous nearby pings (off-axis, asymmetric) -->
    <g fill="currentColor">
      <circle cx="190" cy="220" r="5" fill-opacity="0.7" style="animation: blink-soft 2.6s ease-in-out infinite;"></circle>
      <circle cx="430" cy="180" r="5" fill-opacity="0.7" style="animation: blink-soft 3.2s ease-in-out 0.6s infinite;"></circle>
      <circle cx="160" cy="370" r="5" fill-opacity="0.7" style="animation: blink-soft 2.9s ease-in-out 1.4s infinite;"></circle>
    </g>

    <!-- mutual spark (the moment of recognition) -->
    <g>
      <circle cx="395" cy="395" r="34" fill="none" stroke="currentColor" stroke-opacity="0.5" stroke-width="1" style="transform-origin: 395px 395px; animation: pulse-ring 2.4s ease-out infinite;" />
      <circle cx="395" cy="395" r="14" fill="currentColor" />
      <circle cx="395" cy="395" r="22" fill="none" stroke="currentColor" stroke-opacity="0.95" stroke-width="1.2" />
    </g>

    <!-- center: YOU -->
    <g>
      <circle cx="300" cy="300" r="9" fill="currentColor" />
      <circle cx="300" cy="300" r="20" fill="none" stroke="currentColor" stroke-opacity="0.7" stroke-width="1" />
      <text x="300" y="346" text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="11" letter-spacing="0.28em" fill="currentColor" fill-opacity="0.9" style="text-transform: uppercase;">you</text>
    </g>

    <!-- leader from spark to label box -->
    <line x1="395" y1="395" x2="500" y2="490" stroke="currentColor" stroke-opacity="0.5" stroke-dasharray="2 3" />
  </svg>

  <!-- HUD overlays: status + countdown -->
  <div class="absolute top-2 left-2 font-mono text-[9px] tracking-[0.28em] uppercase text-bzzt/80 flex items-center gap-1.5">
    <span aria-hidden="true" class="block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_6px_var(--color-bzzt)]" style="animation: blink-soft 1.4s infinite;"></span>
    scanning · 3 nearby
  </div>

  <div class="absolute bottom-3 right-3 sm:bottom-6 sm:right-6 text-right">
    <p class="font-mono text-[9px] tracking-[0.28em] uppercase text-bzzt/80 mb-1">▍ Mutual spark</p>
    <p class="font-mono font-bold text-bzzt tracking-[-0.02em] tabular-nums" style="font-size: clamp(1.5rem, 4.2vw, 2.6rem); animation: timer 1.2s ease-in-out infinite;">
      30<span class="text-bzzt/70">:</span>00
    </p>
    <p class="font-mono text-[8px] tracking-[0.32em] uppercase text-bzzt/60 mt-0.5">window · 30 min</p>
  </div>
</div>
