---
import { site } from "../data/site.ts";
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-bg/75 border-b border-line">
  <nav
    aria-label="Primary"
    class="mx-auto max-w-[1600px] px-5 sm:px-8 h-12 flex items-center justify-between font-mono text-[10px] tracking-[0.25em] uppercase"
  >
    <a href="/" class="flex items-center gap-2.5 group" aria-label={`${site.name} — home`}>
      <span aria-hidden="true" class="inline-block w-1.5 h-1.5 rounded-full bg-bzzt shadow-[0_0_10px_var(--color-bzzt)]"></span>
      <span class="text-ink">SWA<span class="text-ink-faint"> · </span>publisher</span>
    </a>

    <div class="hidden sm:flex items-center gap-4 text-ink-faint">
      <span aria-hidden="true">▍ Now showing</span>
      <a href="/#bzzt" class="text-bzzt/80 hover:text-bzzt transition-colors">01 BZZT</a>
      <a href="/#cmok" class="text-cmok/80 hover:text-cmok transition-colors">02 CMOK</a>
      <a href="/#nwd" class="text-nwd/80 hover:text-nwd transition-colors">03 NWD</a>
    </div>

    <ul class="flex items-center gap-4 text-ink-faint">
      <li class="hidden sm:block"><a href="/#company" class="hover:text-ink transition-colors">Company</a></li>
      <li><a href="/legal" class="hover:text-ink transition-colors">Legal ↗</a></li>
    </ul>
  </nav>
</header>
