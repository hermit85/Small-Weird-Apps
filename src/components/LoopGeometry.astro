---
// LoopGeometry — renders a sequence of step labels as nodes on a circular loop.
// 'broken' variant: arcs minus the return → leaves a visible gap, dim/red.
// 'swa'    variant: closed loop + a pulse dot traveling around the perimeter.

type Variant = "broken" | "swa";

interface Props {
  steps: string[];
  variant: Variant;
  accent: "bzzt" | "cmok" | "nwd";
  /** how many seconds for one full lap of the SWA pulse */
  pulseDuration?: number;
}

const { steps, variant, accent, pulseDuration = 6 } = Astro.props;

const cx = 160;
const cy = 160;
const r = 96;
const startDeg = -90;
const n = steps.length;

type Pt = { label: string; x: number; y: number; angleDeg: number };
const points: Pt[] = steps.map((label, i) => {
  const angleDeg = startDeg + (360 / n) * i;
  const angleRad = (angleDeg * Math.PI) / 180;
  return {
    label,
    x: cx + r * Math.cos(angleRad),
    y: cy + r * Math.sin(angleRad),
    angleDeg,
  };
});

const labelOf = (p: Pt) => {
  const angleRad = (p.angleDeg * Math.PI) / 180;
  const lr = r + 28;
  const lx = cx + lr * Math.cos(angleRad);
  const ly = cy + lr * Math.sin(angleRad);
  const cos = Math.cos(angleRad);
  const sin = Math.sin(angleRad);
  const anchor = cos > 0.35 ? "start" : cos < -0.35 ? "end" : "middle";
  // shift y a bit when label is at top/bottom for visual breathing room
  const dy = sin > 0.5 ? 4 : sin < -0.5 ? -2 : 0;
  return { x: lx, y: ly + dy, anchor };
};

// Build arc path between consecutive points (clockwise on screen).
const arc = (a: Pt, b: Pt) =>
  `M ${a.x} ${a.y} A ${r} ${r} 0 0 1 ${b.x} ${b.y}`;

// For broken: draw forward arcs except the last (return). Gap remains visible.
const forwardArcs: string[] = [];
for (let i = 0; i < n - 1; i++) forwardArcs.push(arc(points[i], points[i + 1]));

// Gap midpoint (for "no exit" label) — between last and first node.
const gapMidA = (points[n - 1].angleDeg + 360 + (startDeg)) / 2;
const gapMidR = r;
const gapMidX = cx + gapMidR * Math.cos((gapMidA * Math.PI) / 180);
const gapMidY = cy + gapMidR * Math.sin((gapMidA * Math.PI) / 180);
---

{variant === "broken" ? (
  <svg
    viewBox="0 0 320 320"
    class="w-full h-auto text-flag"
    role="img"
    aria-label={`Broken category loop: ${steps.join(" → ")}, with no return`}
  >
    <!-- baseline ring (very dim, only on the broken side to set the world) -->
    <circle cx={cx} cy={cy} r={r} fill="none" stroke="currentColor" stroke-opacity="0.08" stroke-dasharray="2 5" />

    <!-- forward arcs (the parts of the loop that DO connect) -->
    {forwardArcs.map((d) => (
      <path d={d} stroke="currentColor" stroke-opacity="0.5" stroke-width="1.5" fill="none" stroke-dasharray="6 4" />
    ))}

    <!-- arrow heads at each non-final node -->
    {points.slice(1).map((p, i) => {
      const angleRad = (p.angleDeg * Math.PI) / 180;
      const tx = -Math.sin(angleRad);
      const ty = Math.cos(angleRad);
      return (
        <polygon
          points={`${p.x},${p.y} ${p.x - 8 * ty - 4 * tx},${p.y + 8 * tx - 4 * ty} ${p.x - 8 * ty + 4 * tx},${p.y + 8 * tx + 4 * ty}`}
          fill="currentColor"
          fill-opacity="0.55"
        />
      );
    })}

    <!-- nodes (× style) -->
    {points.map((p) => (
      <Fragment>
        <circle cx={p.x} cy={p.y} r="9" fill="var(--color-bg)" stroke="currentColor" stroke-opacity="0.7" />
        <text x={p.x} y={p.y + 4} text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="11" fill="currentColor" fill-opacity="0.9">×</text>
      </Fragment>
    ))}

    <!-- the broken segment: a fragmented dashed line + a × null label at the gap -->
    <line x1={points[n - 1].x} y1={points[n - 1].y} x2={gapMidX + 6 * Math.cos((gapMidA * Math.PI) / 180 + Math.PI / 2)} y2={gapMidY + 6 * Math.sin((gapMidA * Math.PI) / 180 + Math.PI / 2)} stroke="currentColor" stroke-opacity="0.35" stroke-dasharray="1 4" />
    <line x1={points[0].x} y1={points[0].y} x2={gapMidX - 6 * Math.cos((gapMidA * Math.PI) / 180 + Math.PI / 2)} y2={gapMidY - 6 * Math.sin((gapMidA * Math.PI) / 180 + Math.PI / 2)} stroke="currentColor" stroke-opacity="0.35" stroke-dasharray="1 4" />
    <text x={gapMidX} y={gapMidY + 4} text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" letter-spacing="0.22em" fill="currentColor" fill-opacity="0.7" style="text-transform: uppercase;">× no exit</text>

    <!-- step labels around the perimeter -->
    {points.map((p) => {
      const lp = labelOf(p);
      return (
        <text x={lp.x} y={lp.y} text-anchor={lp.anchor} font-family="JetBrains Mono, monospace" font-weight="600" font-size="13" letter-spacing="0.18em" fill="currentColor" fill-opacity="0.85" style="text-transform: uppercase;">
          {p.label}
        </text>
      );
    })}

    <!-- center: dim "failed" badge -->
    <text x={cx} y={cy + 4} text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="10" letter-spacing="0.32em" fill="currentColor" fill-opacity="0.55" style="text-transform: uppercase;">failed</text>
  </svg>
) : (
  <svg
    viewBox="0 0 320 320"
    class={`w-full h-auto text-${accent}`}
    role="img"
    aria-label={`SWA loop: ${steps.join(" → ")} → repeat`}
  >
    <defs>
      <radialGradient id={`swa-glow-${accent}`} cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="currentColor" stop-opacity="0.18" />
        <stop offset="100%" stop-color="currentColor" stop-opacity="0" />
      </radialGradient>
    </defs>

    <circle cx={cx} cy={cy} r={r + 30} fill={`url(#swa-glow-${accent})`} />

    <!-- closed loop ring (solid, accent) -->
    <circle cx={cx} cy={cy} r={r} fill="none" stroke="currentColor" stroke-opacity="0.42" stroke-width="1.6" />

    <!-- inner faint guide -->
    <circle cx={cx} cy={cy} r={r - 18} fill="none" stroke="currentColor" stroke-opacity="0.10" stroke-dasharray="2 6" />

    <!-- nodes (filled glowing dots) -->
    {points.map((p, i) => (
      <Fragment>
        <circle cx={p.x} cy={p.y} r="14" fill="currentColor" fill-opacity="0.18" style={`transform-origin: ${p.x}px ${p.y}px; animation: pulse-ring 3.6s ease-out ${(i * 0.3).toFixed(2)}s infinite;`} />
        <circle cx={p.x} cy={p.y} r="6" fill="currentColor" />
      </Fragment>
    ))}

    <!-- step labels -->
    {points.map((p) => {
      const lp = labelOf(p);
      return (
        <text x={lp.x} y={lp.y} text-anchor={lp.anchor} font-family="JetBrains Mono, monospace" font-weight="600" font-size="13" letter-spacing="0.18em" fill="currentColor" fill-opacity="0.95" style="text-transform: uppercase;">
          {p.label}
        </text>
      );
    })}

    <!-- traveling pulse: a dot at the top, rotated around center -->
    <g style={`transform-origin: ${cx}px ${cy}px; animation: spin ${pulseDuration}s linear infinite;`}>
      <circle cx={cx} cy={cy - r} r="5" fill="currentColor" />
      <circle cx={cx} cy={cy - r} r="14" fill="none" stroke="currentColor" stroke-opacity="0.6">
      </circle>
    </g>

    <!-- center: live badge with rotating arrow -->
    <text x={cx} y={cy - 2} text-anchor="middle" font-family="JetBrains Mono, monospace" font-weight="700" font-size="10" letter-spacing="0.32em" fill="currentColor" style="text-transform: uppercase;">live</text>
    <text x={cx} y={cy + 14} text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" letter-spacing="0.22em" fill="currentColor" fill-opacity="0.6" style="text-transform: uppercase;">↺ loop</text>
  </svg>
)}
