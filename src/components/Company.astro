---
import { site } from "../data/site.ts";
---

<section id="company" class="relative py-24 sm:py-32 border-t border-line-soft scroll-mt-20">
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <p class="font-mono text-[11px] tracking-[0.22em] uppercase text-ink-faint mb-12 sm:mb-16">
      ▍ Company
    </p>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <div class="lg:col-span-7 space-y-6">
        <p class="font-display text-[clamp(1.8rem,4.5vw,3rem)] leading-[1.1] text-ink">
          {site.name} is a product label by <span class="italic">Cybird Consulting</span>,
          a one-person app publisher based in <span class="italic">{site.city}</span>.
        </p>
        <p class="text-base sm:text-lg leading-relaxed text-ink-dim max-w-xl">
          It publishes small mobile apps built around real-world loops:
          signals, check-ins and offline play.
        </p>
      </div>

      <dl class="lg:col-span-5 grid grid-cols-1 gap-px bg-line rounded-2xl overflow-hidden border border-line">
        <div class="grid grid-cols-3 gap-4 p-5 bg-bg-soft">
          <dt class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Legal owner</dt>
          <dd class="col-span-2 text-ink">{site.legalOwner}</dd>
        </div>
        <div class="grid grid-cols-3 gap-4 p-5 bg-bg-soft">
          <dt class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Based in</dt>
          <dd class="col-span-2 text-ink">{site.city}</dd>
        </div>
        <div class="grid grid-cols-3 gap-4 p-5 bg-bg-soft">
          <dt class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Contact</dt>
          <dd class="col-span-2">
            <a
              href={`mailto:${site.email}`}
              class="text-ink hover:text-bzzt transition-colors underline-offset-4 hover:underline"
            >{site.email}</a>
          </dd>
        </div>
        <div class="grid grid-cols-3 gap-4 p-5 bg-bg-soft">
          <dt class="font-mono text-[10px] tracking-[0.22em] uppercase text-ink-faint">Legal</dt>
          <dd class="col-span-2">
            <a href="/legal" class="text-ink hover:text-bzzt transition-colors underline-offset-4 hover:underline">
              Full legal info →
            </a>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>
