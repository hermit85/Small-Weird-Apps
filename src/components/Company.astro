---
import { site } from "../data/site.ts";
---

<section id="company" class="relative py-24 sm:py-36 border-t border-line scroll-mt-20 overflow-hidden">

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8">

    <!-- header -->
    <div class="grid grid-cols-12 gap-4 sm:gap-8 items-end mb-14 sm:mb-20">
      <div class="col-span-12 md:col-span-3 label text-ink-faint">▍ Section B.05</div>
      <div class="col-span-12 md:col-span-6">
        <p class="callout text-ink-faint">▍ Publisher · colophon</p>
        <h2 class="font-display text-[clamp(2.4rem,7vw,5.5rem)] leading-[0.95] text-ink mt-2">
          The label, <span class="italic text-ink-dim">on paper.</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-3 md:text-right">
        <span class="stamp text-ink-dim">on file · 2026</span>
      </div>
    </div>

    <!-- card-ish, but feels like a folded admission ticket / library card -->
    <div class="relative grid grid-cols-12 gap-0 border-y-2 border-ink/30">

      <!-- perforation column on the left -->
      <div class="hidden md:flex md:col-span-1 flex-col items-center justify-between border-r border-dashed border-ink/30 py-6">
        <span class="callout text-ink-faint" style="writing-mode: vertical-rl; transform: rotate(180deg);">
          PUBLISHER №01
        </span>
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-ink-faint/70"></span>
        <span class="callout text-ink-faint" style="writing-mode: vertical-rl; transform: rotate(180deg);">
          WARSAW · 2026
        </span>
      </div>

      <!-- main body -->
      <div class="col-span-12 md:col-span-7 p-6 sm:p-12 md:border-r border-ink/30">
        <p class="callout text-ink-faint mb-3">▍ Published by</p>
        <p class="font-display text-[clamp(2rem,5vw,3.5rem)] leading-[1] text-ink">
          Cybird Consulting,
          <span class="block italic text-ink-dim">a one-person app publisher</span>
          <span class="block">based in {site.city}.</span>
        </p>

        <p class="mt-10 text-base sm:text-lg leading-relaxed text-ink-dim max-w-xl">
          {site.name} is its product label. It publishes small mobile apps built around
          real-world loops: <span class="text-bzzt">signals</span>,
          <span class="text-cmok">check-ins</span> and
          <span class="text-nwd">offline play</span>.
        </p>

        <!-- "signature line" -->
        <div class="mt-12 sm:mt-16 flex items-end gap-4">
          <div class="flex-1">
            <span class="block w-full border-t border-ink/30"></span>
            <span class="callout text-ink-faint mt-2 block">Legal owner / signature</span>
          </div>
          <span class="font-display italic text-xl sm:text-2xl text-ink">
            {site.legalOwner}
          </span>
        </div>
      </div>

      <!-- right column: contact card -->
      <dl class="col-span-12 md:col-span-4">
        <div class="p-6 sm:p-8 border-t md:border-t-0 border-ink/20">
          <dt class="callout text-ink-faint mb-2">▍ Contact</dt>
          <dd>
            <a
              href={`mailto:${site.email}`}
              class="group inline-flex items-center gap-2 font-display text-2xl sm:text-3xl text-ink hover:text-bzzt transition-colors"
            >
              {site.email}
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">↗</span>
            </a>
          </dd>
        </div>
        <div class="p-6 sm:p-8 border-t border-ink/20">
          <dt class="callout text-ink-faint mb-2">▍ Based in</dt>
          <dd class="font-display text-2xl sm:text-3xl text-ink">{site.city}</dd>
        </div>
        <div class="p-6 sm:p-8 border-t border-ink/20">
          <dt class="callout text-ink-faint mb-2">▍ Full record</dt>
          <dd>
            <a href="/legal" class="group inline-flex items-center gap-2 font-display text-xl sm:text-2xl text-ink hover:text-bzzt transition-colors">
              <span class="italic">Open colophon</span>
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">→</span>
            </a>
          </dd>
        </div>
      </dl>
    </div>

    <!-- catalogue: published apps -->
    <div class="mt-16 sm:mt-24 grid grid-cols-12 gap-4 sm:gap-8 items-baseline">
      <div class="col-span-12 md:col-span-3 label text-ink-faint">
        ▍ Catalogue · current
      </div>
      <ul class="col-span-12 md:col-span-9 divide-y divide-line">
        <li class="grid grid-cols-12 gap-4 py-4 items-baseline">
          <span class="col-span-2 callout text-bzzt/80">Loop 01</span>
          <span class="col-span-3 font-display text-2xl text-ink">BZZT</span>
          <span class="col-span-4 text-ink-dim">Live proximity dating signal.</span>
          <a class="col-span-3 text-right callout text-ink hover:text-bzzt transition-colors" href="https://apps.apple.com/pl/app/bzzt-zone/id6760717645?l=pl" target="_blank" rel="noopener">App Store ↗</a>
        </li>
        <li class="grid grid-cols-12 gap-4 py-4 items-baseline">
          <span class="col-span-2 callout text-cmok/80">Loop 02</span>
          <span class="col-span-3 font-display text-2xl text-ink">CMOK</span>
          <span class="col-span-4 text-ink-dim">Daily soft reassurance loop.</span>
          <span class="col-span-3 text-right callout text-ink-faint">soon</span>
        </li>
        <li class="grid grid-cols-12 gap-4 py-4 items-baseline">
          <span class="col-span-2 callout text-nwd/80">Loop 03</span>
          <span class="col-span-3 font-display text-2xl text-ink">NWD</span>
          <span class="col-span-4 text-ink-dim">Offline race-as-league system.</span>
          <a class="col-span-3 text-right callout text-ink hover:text-nwd transition-colors" href="https://new-world-disorder.vercel.app/" target="_blank" rel="noopener">Open ↗</a>
        </li>
      </ul>
    </div>
  </div>
</section>
