---
import { site } from "../data/site.ts";
---

<section id="company" class="relative py-24 sm:py-36 border-t border-line scroll-mt-20 overflow-hidden">

  <div class="relative mx-auto max-w-[1600px] px-5 sm:px-8">

    <!-- header -->
    <div class="flex items-baseline justify-between gap-4 mb-14 sm:mb-20">
      <p class="font-mono text-[11px] tracking-[0.32em] uppercase text-ink">▍ Publisher plate</p>
      <span aria-hidden="true" class="flex-1 h-px bg-line"></span>
      <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">on file · 2026</p>
    </div>

    <!-- THE PLATE -->
    <div class="relative grid grid-cols-12 gap-0 border-2 border-ink/40 bg-bg-soft/40">

      <!-- left rivets / vertical stamp -->
      <div class="hidden md:flex md:col-span-1 flex-col items-center justify-between border-r border-dashed border-ink/30 py-7">
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-ink-faint/70"></span>
        <span class="callout text-ink-faint" style="writing-mode: vertical-rl; transform: rotate(180deg);">
          Publisher · plate
        </span>
        <span aria-hidden="true" class="block w-2 h-2 rounded-full bg-ink-faint/70"></span>
      </div>

      <!-- main fields -->
      <dl class="col-span-12 md:col-span-7 divide-y divide-ink/15">
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5 sm:py-6">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Label</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl sm:text-3xl text-ink">{site.name}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5 sm:py-6">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Legal owner</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl sm:text-3xl text-ink">{site.legalOwner}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5 sm:py-6">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Base</dt>
          <dd class="col-span-8 md:col-span-9 font-display text-2xl sm:text-3xl text-ink">{site.city}</dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5 sm:py-6">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Contact</dt>
          <dd class="col-span-8 md:col-span-9">
            <a
              href={`mailto:${site.email}`}
              class="group inline-flex items-center gap-2 font-display text-2xl sm:text-3xl text-ink hover:text-bzzt transition-colors"
            >
              {site.email}
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">↗</span>
            </a>
          </dd>
        </div>
        <div class="grid grid-cols-12 gap-4 items-baseline px-6 sm:px-10 py-5 sm:py-6">
          <dt class="col-span-4 md:col-span-3 font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint">Record</dt>
          <dd class="col-span-8 md:col-span-9">
            <a href="/legal" class="group inline-flex items-center gap-2 font-display text-xl sm:text-2xl text-ink hover:text-bzzt transition-colors">
              <span class="italic">Legal page</span>
              <span aria-hidden="true" class="callout transition-transform group-hover:translate-x-1">→</span>
            </a>
          </dd>
        </div>
      </dl>

      <!-- catalogue (current machines, manufactured under this label) -->
      <div class="col-span-12 md:col-span-4 md:border-l border-ink/20 p-6 sm:p-10">
        <p class="font-mono text-[11px] tracking-[0.28em] uppercase text-ink-faint mb-5">▍ Catalogue · current</p>
        <ul class="space-y-5">
          <li class="flex items-baseline justify-between gap-3 pb-3 border-b border-line">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-bzzt/70 w-12">M.01</span>
            <a href="https://apps.apple.com/pl/app/bzzt-zone/id6760717645?l=pl" target="_blank" rel="noopener" class="flex-1 font-mono font-bold uppercase tracking-[-0.02em] text-xl text-ink hover:text-bzzt transition-colors">BZZT</a>
            <span class="callout text-ink-faint">App Store ↗</span>
          </li>
          <li class="flex items-baseline justify-between gap-3 pb-3 border-b border-line">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-cmok/70 w-12">M.02</span>
            <a href="https://apps.apple.com/pl/app/cmok/id6762090888" target="_blank" rel="noopener" class="flex-1 font-display italic lowercase text-xl text-ink hover:text-cmok transition-colors">cmok</a>
            <span class="callout text-ink-faint">App Store ↗</span>
          </li>
          <li class="flex items-baseline justify-between gap-3">
            <span class="font-mono text-[10px] tracking-[0.22em] uppercase text-nwd/70 w-12">M.03</span>
            <a href="https://new-world-disorder.vercel.app/" target="_blank" rel="noopener" class="flex-1 font-display tracking-[-0.02em] text-xl text-ink hover:text-nwd transition-colors">NWD</a>
            <span class="callout text-ink-faint">Open ↗</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- microcopy under the plate -->
    <p class="mt-10 font-display italic text-lg sm:text-xl text-ink-dim max-w-2xl">
      {site.name} is a product label by Cybird Consulting — a one-person mobile app
      publisher building <span class="text-bzzt not-italic">a proximity radar</span>,
      <span class="text-cmok not-italic">a daily ritual</span> and
      <span class="text-nwd not-italic">a gravity league</span>.
    </p>
  </div>
</section>
