---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import ProblemTrio from "../components/ProblemTrio.astro";
import AppStory from "../components/AppStory.astro";
import Manifest from "../components/Manifest.astro";
import Footer from "../components/Footer.astro";

import RadarVisual from "../components/visuals/RadarVisual.astro";
import CircleVisual from "../components/visuals/CircleVisual.astro";
import RaceVisual from "../components/visuals/RaceVisual.astro";

import { apps } from "../data/apps.ts";
const bzzt = apps.find((a) => a.id === "bzzt")!;
const cmok = apps.find((a) => a.id === "cmok")!;
const nwd  = apps.find((a) => a.id === "nwd")!;
---

<Layout>
  <Hero />
  <ProblemTrio />

  <AppStory
    app={bzzt}
    kicker="01 / Dating"
    headline="Dating without endless swiping."
    story="BZZT helps you notice people nearby — without turning dating into profile shopping."
    steps={[
      "See a signal.",
      "Send a signal.",
      "If it's mutual, say hello in real life.",
    ]}
    punch="Less swiping. More actual hello."
    cta="Open in App Store"
  >
    <RadarVisual slot="visual" />
  </AppStory>

  <AppStory
    app={cmok}
    kicker="02 / Safety"
    headline="Safety without panic theatre."
    story="cmok helps close people stay gently connected before anything goes wrong."
    steps={[
      "One tap.",
      "Close circle.",
      "Quiet reassurance.",
    ]}
    punch="Less panic. More presence."
    reverse
    cta="Open in App Store"
  >
    <CircleVisual slot="visual" />
  </AppStory>

  <AppStory
    app={nwd}
    kicker="03 / Racing"
    headline="Racing without waiting for an event."
    story="NWD turns real bike-park trails into an offline downhill racing game."
    steps={[
      "Drop in.",
      "Descent.",
      "Time.",
      "Rank.",
      "Repeat.",
    ]}
    punch="Not a tracker. A gravity league."
    cta="Open NWD"
  >
    <RaceVisual slot="visual" />
  </AppStory>

  <Manifest />
  <Footer />
</Layout>
